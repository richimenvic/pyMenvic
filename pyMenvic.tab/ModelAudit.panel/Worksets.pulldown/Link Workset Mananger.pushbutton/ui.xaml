            </Style.Triggers>
        </Style> -->

        <!-- Centered text inside grid cells -->
        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping"      Value="NoWrap"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>

    </Window.Resources>

    <!-- ================================================================
         ROOT
    ================================================================ -->
    <Grid Background="{StaticResource BgApp}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header   -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar  -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- Footer   -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             HEADER
        ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel LastChildFill="True">
                <Border Width="52" Height="52"
                        Background="#111518"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="3"
                        DockPanel.Dock="Left"
                        Margin="0,0,14,0">
                    <Image x:Name="logoImage" Stretch="Uniform" Margin="7"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Link Workset Manager - pyMENVIC"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextHigh}"/>
                    <TextBlock Text="Auto-detects link discipline and preselects target workset."
                               FontSize="12"
                               Foreground="{StaticResource TextMed}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================
             TOOLBAR
        ============================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnRefresh"
                        Grid.Column="0"
                        Content="REFRESH"
                        Width="100"/>

                <TextBlock Grid.Column="2"
                           Text="FILTER"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMed}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="txtFilter"
                         Grid.Column="4"
                         Height="30"/>
            </Grid>
        </Border>

        <!-- ============================================================
             DATA GRID
        ============================================================ -->
        <DataGrid x:Name="dgLinks" Grid.Row="2">
            <DataGrid.Columns>

                <DataGridTextColumn Header="LINK NAME"
                                    Binding="{Binding LinkName}"
                                    Width="2.10*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="TYPE NAME"
                                    Binding="{Binding TypeName}"
                                    Width="1.80*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="INST WS"
                                    Binding="{Binding CurrentInstanceWorkset}"
                                    Width="0.92*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="TYPE WS"
                                    Binding="{Binding CurrentTypeWorkset}"
                                    Width="0.92*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="STATUS"
                                    Binding="{Binding Status}"
                                    Width="82"
                                    CanUserResize="False"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="PIN"
                                    Binding="{Binding PinnedText}"
                                    Width="54"
                                    CanUserResize="False"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="DISCIPLINE"
                                    Binding="{Binding DisciplineText}"
                                    Width="96"
                                    CanUserResize="False"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="STATE"
                                    Binding="{Binding StateText}"
                                    Width="88"
                                    CanUserResize="False"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"
                               BasedOn="{StaticResource CenteredTextBlockStyle}">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StateText}" Value="OK">
                                    <Setter Property="Foreground" Value="{StaticResource TextOk}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StateText}" Value="CHANGE">
                                    <Setter Property="Foreground" Value="{StaticResource TextWarning}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StateText}" Value="REVIEW">
                                    <Setter Property="Foreground" Value="{StaticResource TextDanger}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Warning icon -->
                <DataGridTemplateColumn Header=""
                                        Width="34"
                                        CanUserResize="False"
                                        IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <TextBlock Text="!"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        Foreground="{StaticResource TextWarning}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ToolTip="{Binding WarningText}"
                                        Visibility="{Binding IsUnrecognized, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Target workset (editable combo) -->
                <DataGridTemplateColumn Header="TARGET WORKSET" Width="1.08*">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell"
                            BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Focusable" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingChange}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BgPending}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUnrecognized}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderWarning}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <ComboBox ItemsSource="{Binding WorksetOptions}"
                                    SelectedItem="{Binding SelectedTargetWorksetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource GridComboStyle}"
                                    FocusVisualStyle="{x:Null}"
                                    IsEditable="False"
                                    IsTextSearchEnabled="True"
                                    StaysOpenOnEdit="False"/>
                             </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ============================================================
             FOOTER
        ============================================================ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <DockPanel LastChildFill="False">

                <TextBlock x:Name="txtStatus"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource TextMed}"
                           Text="Links: 0 | OK: 0 | Pending: 0 | Review: 0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="btnApply"
                            Content="APPLY"
                            Style="{StaticResource GreenBtnStyle}"/>
                    <Button x:Name="btnCancel"
                            Content="CLOSE"
                            Style="{StaticResource RedBtnStyle}"
