<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Link Worksets - pyMENVIC"
        Width="940" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E252B">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#1E252B" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#26303A" />
        <SolidColorBrush x:Key="ContentBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="FooterTextBrush" Color="#A9BAC8" />
        <SolidColorBrush x:Key="HeaderLabelBrush" Color="#8FA7BA" />
        <Style x:Key="ToolButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="White" /><Setter Property="Background" Value="#2F4B5E" /><Setter Property="BorderBrush" Value="#4C6B82" /><Setter Property="Height" Value="30" /><Setter Property="MinWidth" Value="96" /><Setter Property="Padding" Value="12,4" /><Setter Property="Margin" Value="0,0,6,0" /></Style>
        <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}"><Setter Property="Background" Value="#2D9D55" /><Setter Property="BorderBrush" Value="#49B571" /></Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="#1E252B" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="#F7F9FB" /><Setter Property="Foreground" Value="#1E252B" /><Setter Property="BorderBrush" Value="#9FB3C1" /><Setter Property="Height" Value="30" /><Setter Property="Padding" Value="6,4" /><Setter Property="VerticalContentAlignment" Value="Center" /></Style>
        <Style TargetType="ComboBox"><Setter Property="Background" Value="#F7F9FB" /><Setter Property="Foreground" Value="#1E252B" /><Setter Property="BorderBrush" Value="#9FB3C1" /><Setter Property="Height" Value="30" /><Setter Property="VerticalContentAlignment" Value="Center" /></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="#1E252B" /><Setter Property="VerticalAlignment" Value="Center" /></Style>
        <Style TargetType="DataGrid"><Setter Property="AutoGenerateColumns" Value="False" /><Setter Property="CanUserAddRows" Value="False" /><Setter Property="Background" Value="#F7F9FB" /><Setter Property="Foreground" Value="#1E252B" /><Setter Property="RowBackground" Value="#FFFFFF" /><Setter Property="AlternatingRowBackground" Value="#F0F3F6" /><Setter Property="GridLinesVisibility" Value="All" /><Setter Property="HorizontalGridLinesBrush" Value="#C8D1D8" /><Setter Property="VerticalGridLinesBrush" Value="#C8D1D8" /><Setter Property="RowHeight" Value="28" /><Setter Property="ColumnHeaderHeight" Value="26" /><Setter Property="SelectionMode" Value="Single" /><Setter Property="SelectionUnit" Value="FullRow" /></Style>
        <Style TargetType="DataGridRow"><Setter Property="Foreground" Value="#1E252B" /><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#0A70B8" /><Setter Property="Foreground" Value="White" /><Setter Property="FontWeight" Value="SemiBold" /></Trigger></Style.Triggers></Style>
        <Style TargetType="DataGridCell"><Setter Property="BorderBrush" Value="#C8D1D8" /><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#0A70B8" /><Setter Property="Foreground" Value="White" /></Trigger></Style.Triggers></Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#E9EEF3" /><Setter Property="Foreground" Value="#1E252B" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Padding" Value="6,4" /></Style>
    </Window.Resources>
    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="10"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><Image x:Name="logo_image" Width="28" Height="28" Stretch="Uniform" /><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock x:Name="title_text" Text="SYNC LINK WORKSETS" FontSize="18" FontWeight="Bold" Foreground="White" /><TextBlock x:Name="subtitle_text" Text="Detect worksets in loaded links, filter the list, and create only the selected ones in the host model." FontSize="11" Foreground="{StaticResource HeaderLabelBrush}" /></StackPanel><StackPanel Grid.Column="2" Margin="8,0,0,0"><TextBlock Text="WORKSETS" Foreground="{StaticResource HeaderLabelBrush}" FontSize="10" /><TextBlock x:Name="summary_text" Text="0/0" Foreground="White" FontSize="15" FontWeight="Bold" /></StackPanel><StackPanel Grid.Column="3" Margin="18,0,0,0"><TextBlock Text="LINKED" Foreground="{StaticResource HeaderLabelBrush}" FontSize="10" /><TextBlock x:Name="linked_text" Text="0" Foreground="White" FontSize="15" FontWeight="Bold" /></StackPanel><StackPanel Grid.Column="4" Margin="18,0,0,0"><TextBlock Text="CHECKED" Foreground="{StaticResource HeaderLabelBrush}" FontSize="10" /><TextBlock x:Name="checked_text" Text="0" Foreground="White" FontSize="15" FontWeight="Bold" /></StackPanel></Grid></Border>
        <Border Grid.Row="1" Background="{StaticResource ContentBrush}" Padding="18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Grid.Row="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,12" BorderBrush="#C8D1D8" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Grid.Column="0" Margin="0,0,14,0"><TextBlock x:Name="link_filter_label" Text="LINK FILTER" Style="{StaticResource SectionLabelStyle}" /><ComboBox x:Name="link_filter_combo" /></StackPanel><StackPanel Grid.Column="1" Margin="0,0,14,0"><TextBlock x:Name="search_label" Text="SEARCH WORKSET" Style="{StaticResource SectionLabelStyle}" /><TextBox x:Name="search_box" /></StackPanel><CheckBox Grid.Column="2" x:Name="only_missing_check" Content="ONLY MISSING" Margin="0,20,18,0" /><Button Grid.Column="3" x:Name="refresh_button" Content="REFRESH" Style="{StaticResource ToolButtonStyle}" VerticalAlignment="Bottom" /></Grid></Border>
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="14" BorderBrush="#C8D1D8" BorderThickness="1"><DataGrid x:Name="worksets_grid"><DataGrid.Columns>
            <DataGridTemplateColumn Width="48"><DataGridTemplateColumn.Header><TextBlock x:Name="col_use_text" Text="USE" /></DataGridTemplateColumn.Header><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="on_grid_selection_changed" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Width="240"><DataGridTemplateColumn.Header><TextBlock x:Name="col_workset_text" Text="WORKSET" /></DataGridTemplateColumn.Header><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding WorksetName}" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Width="90"><DataGridTemplateColumn.Header><TextBlock x:Name="col_status_text" Text="STATUS" /></DataGridTemplateColumn.Header><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Status}" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#2D9D55" /><Style.Triggers><DataTrigger Binding="{Binding IsMissing}" Value="True"><Setter Property="Foreground" Value="#B7791F" /></DataTrigger><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True"><Setter Property="Foreground" Value="White" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Width="*"><DataGridTemplateColumn.Header><TextBlock x:Name="col_source_links_text" Text="SOURCE LINKS" /></DataGridTemplateColumn.Header><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding SourceLinksText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
            <DataGridTemplateColumn Width="70"><DataGridTemplateColumn.Header><TextBlock x:Name="col_link_count_text" Text="LINKS" /></DataGridTemplateColumn.Header><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding SourceCountText}" HorizontalAlignment="Center" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
        </DataGrid.Columns></DataGrid></Border></Grid></Border>
        <Border Grid.Row="2" Background="{StaticResource WindowBrush}" Padding="18,10,18,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="footer_info_text" Text="Only missing checked rows will be created." VerticalAlignment="Center" Foreground="{StaticResource FooterTextBrush}" FontSize="12" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Button x:Name="check_visible_button" Content="CHECK VISIBLE" Style="{StaticResource ToolButtonStyle}" /><Button x:Name="uncheck_visible_button" Content="UNCHECK VISIBLE" Style="{StaticResource ToolButtonStyle}" /><Button x:Name="check_missing_button" Content="CHECK MISSING" Style="{StaticResource ToolButtonStyle}" /><Button x:Name="create_button" Content="CREATE SELECTED" Style="{StaticResource ApplyButtonStyle}" /><Button x:Name="close_button" Content="CLOSE" Style="{StaticResource ToolButtonStyle}" /></StackPanel></Grid></Border>
    </Grid>
</Window>
