<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Manager Pro" Height="920" Width="1620"
        Background="#1E252B" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style x:Key="ToolButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#2F4B5E"/>
      <Setter Property="BorderBrush" Value="#4C6B82"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
    <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
      <Setter Property="Background" Value="#2D9D55"/>
      <Setter Property="BorderBrush" Value="#49B571"/>
    </Style>
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
      <Setter Property="Background" Value="#7A3430"/>
      <Setter Property="BorderBrush" Value="#9A4A45"/>
    </Style>
    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="ValueBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="#F7F9FB"/>
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="BorderBrush" Value="#9FB3C1"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#F7F9FB"/>
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#1E252B"/>
    </Style>
    <Style TargetType="DataGrid">
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="Background" Value="#F7F9FB"/>
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="RowBackground" Value="#FFFFFF"/>
      <Setter Property="AlternatingRowBackground" Value="#F0F3F6"/>
      <Setter Property="GridLinesVisibility" Value="All"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#C8D1D8"/>
      <Setter Property="VerticalGridLinesBrush" Value="#C8D1D8"/>
      <Setter Property="RowHeight" Value="22"/>
      <Setter Property="ColumnHeaderHeight" Value="26"/>
      <Setter Property="SelectionMode" Value="Single"/>
      <Setter Property="SelectionUnit" Value="FullRow"/>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Foreground" Value="#1E252B"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#0A70B8"/>
          <Setter Property="Foreground" Value="White"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="BorderBrush" Value="#C8D1D8"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#0A70B8"/>
          <Setter Property="Foreground" Value="White"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#E9EEF3"/>
      <Setter Property="Foreground" Value="#1E252B"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="#C3D1DD"/>
      <Setter Property="Background" Value="#24323E"/>
      <Setter Property="Padding" Value="14,8"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#1E252B"/>
          <Setter Property="Background" Value="#DCE7EF"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Foreground" Value="#1E252B"/>
          <Setter Property="Background" Value="#F4F6F8"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="3" Background="#1E252B">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="4"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#26303A" Padding="10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Image x:Name="HeaderLogoImage" Width="28" Height="28" Margin="0,0,8,0"/>
          <TextBlock Text="FILTER MANAGER PRO - pyMENVIC" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
          <Border x:Name="HeaderCardBorder1" Width="62" Background="#1F2B35" BorderBrush="#344B5B" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="4,0"><StackPanel HorizontalAlignment="Center"><TextBlock x:Name="HeaderCardLabel1" Foreground="#8FA7BA" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"/><TextBlock x:Name="HeaderCardValue1" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/></StackPanel></Border>
          <Border x:Name="HeaderCardBorder2" Width="62" Background="#1F2B35" BorderBrush="#344B5B" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="4,0"><StackPanel HorizontalAlignment="Center"><TextBlock x:Name="HeaderCardLabel2" Foreground="#8FA7BA" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"/><TextBlock x:Name="HeaderCardValue2" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/></StackPanel></Border>
          <Border x:Name="HeaderCardBorder3" Width="62" Background="#1F2B35" BorderBrush="#344B5B" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="4,0"><StackPanel HorizontalAlignment="Center"><TextBlock x:Name="HeaderCardLabel3" Foreground="#8FA7BA" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"/><TextBlock x:Name="HeaderCardValue3" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/></StackPanel></Border>
          <Border x:Name="HeaderCardBorder4" Width="68" Background="#1F2B35" BorderBrush="#344B5B" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="4,0"><StackPanel HorizontalAlignment="Center"><TextBlock x:Name="HeaderCardLabel4" Foreground="#8FA7BA" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"/><TextBlock x:Name="HeaderCardValue4" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/></StackPanel></Border>
        </WrapPanel>
      </Grid>
    </Border>

    <TabControl x:Name="MainTabControl" Grid.Row="2" Background="#1E252B" SelectionChanged="MainTabControl_SelectionChanged">
      <TabItem Header="Audit">
        <Grid Margin="2" Background="#F4F6F8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="230"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="215" MinHeight="125"/>
            <RowDefinition Height="34"/>
          </Grid.RowDefinitions>
          <Border Padding="6">
            <WrapPanel>
              <TextBlock Text="Search" Style="{StaticResource SectionLabelStyle}"/>
              <TextBox x:Name="AuditSearchTextBox" Width="240" Style="{StaticResource ValueBoxStyle}" TextChanged="AuditSearchTextBox_TextChanged"/>
              <TextBlock Text="Scope" Style="{StaticResource SectionLabelStyle}" Margin="12,0,6,0"/>
              <ComboBox x:Name="AuditScopeComboBox" Width="190" SelectionChanged="AuditScopeComboBox_SelectionChanged">
                <ComboBoxItem Content="All Filters"/>
                <ComboBoxItem Content="Unused Only"/>
                <ComboBoxItem Content="Used Only"/>
                <ComboBoxItem Content="Duplicates Only"/>
              </ComboBox>
              <Button x:Name="RefreshAuditButton" Content="Refresh Audit" Style="{StaticResource ToolButtonStyle}" Click="RefreshAuditButton_Click" Margin="8,0,0,0"/>
              <Button x:Name="OpenRevitFiltersButton" Content="Open Revit Filters" Style="{StaticResource ToolButtonStyle}" Click="OpenRevitFiltersButton_Click" Margin="2,0,0,0"/>
            </WrapPanel>
          </Border>
          <TextBlock x:Name="AuditStatusTextBlock" Grid.Row="1" Foreground="#0A70B8" Margin="2,4"/>
          <DataGrid x:Name="AuditGrid" Grid.Row="2" AutoGenerateColumns="False" CellEditEnding="AuditGrid_CellEditEnding" SelectionChanged="AuditGrid_SelectionChanged">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Purge" Width="60">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding Purge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Focusable="False"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="2*"/>
              <DataGridTextColumn Header="Categories" Binding="{Binding Categories}" IsReadOnly="True" Width="1.35*"/>
              <DataGridTextColumn Header="Views" Binding="{Binding ViewCount}" IsReadOnly="True" Width="60"/>
              <DataGridTextColumn Header="Templates" Binding="{Binding TemplateCount}" IsReadOnly="True" Width="78"/>
              <DataGridTextColumn Header="Total" Binding="{Binding TotalCount}" IsReadOnly="True" Width="58"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="70"/>
              <DataGridTextColumn Header="Duplicate Type" Binding="{Binding DuplicateType}" IsReadOnly="True" Width="130"/>
              <DataGridTextColumn Header="Duplicate Set" Binding="{Binding DuplicateGroup}" IsReadOnly="True" Width="150"/>
            </DataGrid.Columns>
          </DataGrid>
          <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#B8C6D1" ShowsPreview="True"/>
          <Border Grid.Row="4" Background="White" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8" Margin="0,3">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Background="#E6EDF3" BorderBrush="#AAB8C4" BorderThickness="0,0,0,1" Padding="6,3" Margin="0,0,0,6">
                <TextBlock Text="FILTER DETAILS" FontWeight="Bold" Foreground="#1E252B" FontSize="13"/>
              </Border>
              <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30*"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="25*"/>
                  <ColumnDefinition Width="8"/>
                  <ColumnDefinition Width="45*"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer x:Name="AuditDetailsFilterScrollViewer" Grid.Column="0" VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="FILTER" FontWeight="Bold" Foreground="#1E252B" Margin="0,0,0,4"/>
                    <TextBlock x:Name="AuditDetailsFilterTextBlock" Text="Select a filter." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                  </StackPanel>
                </ScrollViewer>
                <Border Grid.Column="1" Background="#C2CCD5" Width="1" HorizontalAlignment="Center"/>
                <ScrollViewer x:Name="AuditDetailsDuplicateScrollViewer" Grid.Column="2" VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="DUPLICATE" FontWeight="Bold" Foreground="#1E252B" Margin="0,0,0,4"/>
                    <TextBlock x:Name="AuditDetailsDuplicateTextBlock" Text="Duplicate information will appear here." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                  </StackPanel>
                </ScrollViewer>
                <Border Grid.Column="3" Background="#C2CCD5" Width="1" HorizontalAlignment="Center"/>
                <ScrollViewer x:Name="AuditDetailsRulesScrollViewer" Grid.Column="4" VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="RULES" FontWeight="Bold" Foreground="#1E252B" Margin="0,0,0,4"/>
                    <TextBlock x:Name="AuditDetailsRulesTextBlock" Text="Rules will appear here." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Grid>
          </Border>
          <Border Grid.Row="5" Background="#F4F6F8" Padding="0,3,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button x:Name="PurgeSelectedUnusedButton" Content="Purge Selected Unused" Style="{StaticResource DangerButtonStyle}" Width="170" Height="28" Visibility="Collapsed" Click="PurgeSelectedUnusedButton_Click"/>
              <Button x:Name="ApplyAuditChangesButton" Content="Apply Audit Changes" Style="{StaticResource ApplyButtonStyle}" Width="165" Height="28" IsEnabled="False" Click="ApplyAuditChangesButton_Click"/>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Rename / Standardize">
        <Grid Margin="2" Background="#F4F6F8">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <Border Padding="6"><WrapPanel><TextBlock Text="Search" Style="{StaticResource SectionLabelStyle}"/><TextBox x:Name="RenameSearchTextBox" Width="140" Style="{StaticResource ValueBoxStyle}" TextChanged="RenameSearchTextBox_TextChanged"/><TextBlock Text="Find" Style="{StaticResource SectionLabelStyle}" Margin="12,0,6,0"/><TextBox x:Name="FindTextBox" Width="120" Style="{StaticResource ValueBoxStyle}"/><TextBlock Text="Replace With" Style="{StaticResource SectionLabelStyle}" Margin="12,0,6,0"/><TextBox x:Name="ReplaceTextBox" Width="120" Style="{StaticResource ValueBoxStyle}"/><TextBlock Text="Prefix" Style="{StaticResource SectionLabelStyle}" Margin="12,0,6,0"/><TextBox x:Name="RenamePrefixTextBox" Width="120" Style="{StaticResource ValueBoxStyle}"/><TextBlock Text="Suffix" Style="{StaticResource SectionLabelStyle}" Margin="12,0,6,0"/><TextBox x:Name="RenameSuffixTextBox" Width="120" Style="{StaticResource ValueBoxStyle}"/><CheckBox x:Name="UppercaseCheckBox" Content="Uppercase" Margin="12,0,8,0"/><Button x:Name="PreviewRenameButton" Content="Preview" Style="{StaticResource ToolButtonStyle}" Click="PreviewRenameButton_Click"/></WrapPanel></Border>
          <TextBlock x:Name="RenameStatusTextBlock" Grid.Row="1" Foreground="#0A70B8" Margin="2,4"/>
          <DataGrid x:Name="RenameGrid" Grid.Row="2" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Apply" Binding="{Binding Apply}" Width="60"/><DataGridTextColumn Header="Current Name" Binding="{Binding CurrentName}" IsReadOnly="True" Width="*"/><DataGridTextColumn Header="Proposed Name" Binding="{Binding ProposedName}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="130"/></DataGrid.Columns></DataGrid>
          <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="ResetRenameRowButton" Content="Reset Selected Row" Click="ResetRenameRowButton_Click" Style="{StaticResource ToolButtonStyle}"/><Button x:Name="ApplyRenameButton" Content="Apply Rename" Click="ApplyRenameButton_Click" Style="{StaticResource ApplyButtonStyle}"/></StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Replace / Consolidate">
        <Grid Margin="2" Background="#F4F6F8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Border Padding="8" Background="#F4F6F8">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Row="0" Grid.Column="0" Background="#FFFFFF" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Source Filter" Style="{StaticResource SectionLabelStyle}"/>
                  <ComboBox x:Name="SourceComboBox" Grid.Column="1" MinWidth="260"/>
                </Grid>
              </Border>
              <Border Grid.Row="0" Grid.Column="2" Background="#FFFFFF" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Target Filter" Style="{StaticResource SectionLabelStyle}"/>
                  <ComboBox x:Name="TargetComboBox" Grid.Column="1" MinWidth="260"/>
                </Grid>
              </Border>
              <Border Grid.Row="1" Grid.Column="0" Background="#E6EDF3" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                  <TextBlock Text="SCOPE" Foreground="#1E252B" FontWeight="Bold" FontSize="11" Margin="0,0,0,5"/>
                  <WrapPanel>
                    <CheckBox x:Name="IncludeViewsCheckBox" Content="Include Views" IsChecked="True" Foreground="#1E252B" Margin="0,0,18,0"/>
                    <CheckBox x:Name="IncludeTemplatesCheckBox" Content="Include Templates" IsChecked="True" Foreground="#1E252B" Margin="0,0,18,0"/>
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Grid.Column="2" Background="#E6EDF3" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                  <TextBlock Text="OPTIONS" Foreground="#1E252B" FontWeight="Bold" FontSize="11" Margin="0,0,0,5"/>
                  <WrapPanel>
                    <CheckBox x:Name="MergeExistingCheckBox" Content="Merge if Target Exists" IsChecked="True" Foreground="#1E252B" Margin="0,0,18,0"/>
                    <CheckBox x:Name="CopyVisibilityCheckBox" Content="Copy Visibility" IsChecked="True" Foreground="#1E252B" Margin="0,0,18,0"/>
                    <CheckBox x:Name="CopyEnabledCheckBox" Content="Copy Enabled/Active" IsChecked="True" Foreground="#1E252B" Margin="0,0,18,0"/>
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#FFFFFF" BorderBrush="#B8C6D1" BorderThickness="1" Padding="8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="135"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Search" Style="{StaticResource SectionLabelStyle}"/>
                  <TextBox x:Name="ReplaceSearchTextBox" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" TextChanged="ReplaceSearchTextBox_TextChanged"/>
                  <Button x:Name="PreviewReplaceButton" Grid.Column="2" Content="Preview" Style="{StaticResource ToolButtonStyle}" Click="PreviewReplaceButton_Click" Margin="10,0,0,0"/>
                  <TextBlock Grid.Column="3" Text="Show" Style="{StaticResource SectionLabelStyle}" Margin="10,0,6,0"/>
                  <ComboBox x:Name="ReplaceShowComboBox" Grid.Column="4" SelectionChanged="ReplaceShowComboBox_SelectionChanged">
                    <ComboBoxItem Content="All"/>
                    <ComboBoxItem Content="Ready"/>
                    <ComboBoxItem Content="Already Target"/>
                  </ComboBox>
                  <TextBlock Grid.Column="5" Text="Preview reads view/template usage only. Apply remains disabled until rows are ready." Foreground="#6C7A86" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
              </Border>
            </Grid>
          </Border>
          <Border Grid.Row="1" Background="#E6EDF3" BorderBrush="#AAB8C4" BorderThickness="1" Padding="8,5" Margin="8,0,8,6">
            <TextBlock x:Name="ReplaceStatusTextBlock" Foreground="#0A70B8" FontWeight="SemiBold"/>
          </Border>
          <DataGrid x:Name="ReplaceGrid" Grid.Row="2" AutoGenerateColumns="False" Margin="8,0,8,6">
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Header="Apply" Binding="{Binding Apply}" Width="56"/>
              <DataGridTextColumn Header="View / Template" Binding="{Binding ViewName}" Width="2.15*"/>
              <DataGridTemplateColumn Header="Type" Width="1.1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Grid>
                      <TextBlock x:Name="RawTypeText" Text="{Binding ViewKind}" Padding="4,0" VerticalAlignment="Center"/>
                      <TextBlock x:Name="TypeText" Text="3D View" Padding="4,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                    <DataTemplate.Triggers>
                      <DataTrigger Binding="{Binding ViewKind}" Value="ThreeD">
                        <Setter TargetName="RawTypeText" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="TypeText" Property="Text" Value="3D View"/>
                        <Setter TargetName="TypeText" Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding ViewKind}" Value="FloorPlan">
                        <Setter TargetName="RawTypeText" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="TypeText" Property="Text" Value="Floor Plan"/>
                        <Setter TargetName="TypeText" Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding ViewKind}" Value="ThreeD"/>
                          <Condition Binding="{Binding IsTemplate}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter TargetName="TypeText" Property="Text" Value="3D View Template"/>
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding ViewKind}" Value="FloorPlan"/>
                          <Condition Binding="{Binding IsTemplate}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter TargetName="TypeText" Property="Text" Value="Floor Plan Template"/>
                      </MultiDataTrigger>
                    </DataTemplate.Triggers>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridCheckBoxColumn Header="Template" Binding="{Binding IsTemplate}" IsReadOnly="True" Width="78"/>
              <DataGridCheckBoxColumn Header="Source" Binding="{Binding HasSource}" IsReadOnly="True" Width="72"/>
              <DataGridCheckBoxColumn Header="Target" Binding="{Binding HasTarget}" IsReadOnly="True" Width="72"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="1.5*"/>
            </DataGrid.Columns>
          </DataGrid>
          <Border Grid.Row="3" Background="#F4F6F8" Padding="8,2,8,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock Text="Review preview rows before applying." Foreground="#6C7A86" VerticalAlignment="Center" Margin="0,0,10,0"/>
              <Button x:Name="ApplyReplaceButton" Content="Apply Replace" Style="{StaticResource ApplyButtonStyle}" Width="150" Height="32" IsEnabled="False" Click="ApplyReplaceButton_Click"/>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Reports"><StackPanel Margin="6" Background="#F4F6F8"><TextBlock Text="Export current audit, unused filter, and replace preview data to CSV reports."/><TextBlock x:Name="ReportsStatusTextBlock" Foreground="#0A70B8"/><Button x:Name="ExportAuditCsvButton" Content="Export Audit Summary CSV" Click="ExportAuditCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="260"/><Button x:Name="ExportUnusedCsvButton" Content="Export Unused Filters CSV" Click="ExportUnusedCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="260"/><Button x:Name="ExportReplaceCsvButton" Content="Export Replace Preview CSV" Click="ExportReplaceCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="260"/></StackPanel></TabItem>
    </TabControl>

    <Border Grid.Row="3" Background="#1E252B" BorderThickness="0" Padding="3,4,3,1" Margin="0,2,0,0">
      <TextBlock x:Name="FooterVersionTextBlock" Text="" Foreground="#A9BAC8" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
    </Border>
  </Grid>
</Window>
