<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Filter Manager Pro" Height="920" Width="1620" Background="#1E252B" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#0A84D6"/>
    <Style x:Key="ToolButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#355266"/>
      <Setter Property="BorderBrush" Value="#4A6C85"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
  </Window.Resources>
  <Grid Margin="12">
  </Grid>
</Window>
