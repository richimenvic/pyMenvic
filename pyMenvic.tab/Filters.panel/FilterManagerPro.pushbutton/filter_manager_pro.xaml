<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Filter Manager Pro" Height="920" Width="1620" Background="#1E252B" WindowStartupLocation="CenterScreen">
<Window.Resources>
<SolidColorBrush x:Key="AccentStrongBrush" Color="#0A84D6"/><Style x:Key="ToolButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="{StaticResource AccentStrongBrush}"/><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="12,4"/></Style>
<Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}"><Setter Property="Background" Value="#2D9D55"/></Style>
<Style TargetType="DataGrid"><Setter Property="CanUserAddRows" Value="False"/></Style>
</Window.Resources>
<Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
<Border Grid.Row="0" Background="#26303A" Padding="10"><DockPanel><StackPanel Orientation="Horizontal" DockPanel.Dock="Left"><Image x:Name="HeaderLogoImage" Width="24" Height="24" Margin="0,0,8,0"/><TextBlock Text="FILTER MANAGER PRO - pyMENVIC" Foreground="White" FontSize="18"/></StackPanel><WrapPanel DockPanel.Dock="Right"><Border x:Name="HeaderCardBorder1"><StackPanel><TextBlock x:Name="HeaderCardLabel1"/><TextBlock x:Name="HeaderCardValue1"/></StackPanel></Border><Border x:Name="HeaderCardBorder2"><StackPanel><TextBlock x:Name="HeaderCardLabel2"/><TextBlock x:Name="HeaderCardValue2"/></StackPanel></Border><Border x:Name="HeaderCardBorder3"><StackPanel><TextBlock x:Name="HeaderCardLabel3"/><TextBlock x:Name="HeaderCardValue3"/></StackPanel></Border><Border x:Name="HeaderCardBorder4"><StackPanel><TextBlock x:Name="HeaderCardLabel4"/><TextBlock x:Name="HeaderCardValue4"/></StackPanel></Border><Border x:Name="HeaderCardBorder5"><StackPanel><TextBlock x:Name="HeaderCardLabel5"/><TextBlock x:Name="HeaderCardValue5"/></StackPanel></Border><Border x:Name="HeaderCardBorder6"><StackPanel><TextBlock x:Name="HeaderCardLabel6"/><TextBlock x:Name="HeaderCardValue6"/></StackPanel></Border></WrapPanel></DockPanel></Border>
<TabControl x:Name="MainTabControl" Grid.Row="2" SelectionChanged="MainTabControl_SelectionChanged">
<TabItem Header="Audit"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal"><Button x:Name="RefreshAuditButton" Content="Refresh Audit" Style="{StaticResource ToolButtonStyle}" Click="RefreshAuditButton_Click"/></StackPanel><DataGrid x:Name="AuditGrid" Grid.Row="1" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="*"/><DataGridTextColumn Header="Categories" Binding="{Binding Categories}" Width="2*"/><DataGridTextColumn Header="Views" Binding="{Binding ViewCount}"/><DataGridTextColumn Header="Templates" Binding="{Binding TemplateCount}"/><DataGridTextColumn Header="Total" Binding="{Binding TotalCount}"/><DataGridTextColumn Header="Status" Binding="{Binding Status}"/><DataGridTextColumn Header="Duplicate" Binding="{Binding Duplicate}"/></DataGrid.Columns></DataGrid></Grid></TabItem>
<TabItem Header="Rename / Standardize"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><WrapPanel><TextBlock Text="Search" Foreground="White" Margin="0,0,6,0"/><TextBox x:Name="RenameSearchTextBox" Width="140" TextChanged="RenameSearchTextBox_TextChanged"/><TextBlock Text="Find" Foreground="White" Margin="8,0,6,0"/><TextBox x:Name="FindTextBox" Width="120"/><TextBlock Text="Replace" Foreground="White" Margin="8,0,6,0"/><TextBox x:Name="ReplaceTextBox" Width="120"/><TextBlock Text="Prefix" Foreground="White" Margin="8,0,6,0"/><TextBox x:Name="RenamePrefixTextBox" Width="120"/><TextBlock Text="Suffix" Foreground="White" Margin="8,0,6,0"/><TextBox x:Name="RenameSuffixTextBox" Width="120"/><CheckBox x:Name="UppercaseCheckBox" Content="UPPERCASE" Foreground="White" Margin="8,0,0,0"/><Button x:Name="PreviewRenameButton" Content="Preview" Margin="8,0,0,0" Style="{StaticResource ToolButtonStyle}" Click="PreviewRenameButton_Click"/></WrapPanel><TextBlock x:Name="RenameStatusTextBlock" Grid.Row="1" Foreground="#7EC8FF"/><DataGrid x:Name="RenameGrid" Grid.Row="2" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Apply" Binding="{Binding Apply}"/><DataGridTextColumn Header="Current Name" Binding="{Binding CurrentName}" IsReadOnly="True" Width="*"/><DataGridTextColumn Header="Proposed Name" Binding="{Binding ProposedName}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}"/></DataGrid.Columns></DataGrid><StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="ResetRenameRowButton" Content="Reset Selected Row" Click="ResetRenameRowButton_Click" Style="{StaticResource ToolButtonStyle}" Margin="0,0,8,0"/><Button x:Name="ApplyRenameButton" Content="Apply Rename" Click="ApplyRenameButton_Click" Style="{StaticResource ApplyButtonStyle}"/></StackPanel></Grid></TabItem>
<TabItem Header="Replace / Consolidate"><Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><WrapPanel><TextBlock Text="Source" Foreground="White"/><ComboBox x:Name="SourceComboBox" Width="260" Margin="6,0,12,0"/><TextBlock Text="Target" Foreground="White"/><ComboBox x:Name="TargetComboBox" Width="260" Margin="6,0,12,0"/><CheckBox x:Name="IncludeViewsCheckBox" Content="Include Views" Foreground="White" IsChecked="True"/><CheckBox x:Name="IncludeTemplatesCheckBox" Content="Include Templates" Foreground="White" IsChecked="True"/><CheckBox x:Name="MergeExistingCheckBox" Content="Merge Existing" Foreground="White" IsChecked="True"/><CheckBox x:Name="CopyVisibilityCheckBox" Content="Copy Visibility" Foreground="White" IsChecked="True"/><CheckBox x:Name="CopyEnabledCheckBox" Content="Copy Enabled" Foreground="White" IsChecked="True"/><TextBlock Text="Search" Foreground="White" Margin="8,0,6,0"/><TextBox x:Name="ReplaceSearchTextBox" Width="160" TextChanged="ReplaceSearchTextBox_TextChanged"/><Button x:Name="PreviewReplaceButton" Content="Preview" Margin="8,0,0,0" Style="{StaticResource ToolButtonStyle}" Click="PreviewReplaceButton_Click"/></WrapPanel><TextBlock x:Name="ReplaceStatusTextBlock" Grid.Row="1" Foreground="#7EC8FF"/><DataGrid x:Name="ReplaceGrid" Grid.Row="2" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="Apply" Binding="{Binding Apply}"/><DataGridTextColumn Header="View / Template" Binding="{Binding ViewName}" Width="*"/><DataGridTextColumn Header="Type" Binding="{Binding ViewKind}"/><DataGridCheckBoxColumn Header="Template" Binding="{Binding IsTemplate}"/><DataGridCheckBoxColumn Header="Has Source" Binding="{Binding HasSource}"/><DataGridCheckBoxColumn Header="Has Target" Binding="{Binding HasTarget}"/><DataGridTextColumn Header="Status" Binding="{Binding Status}"/></DataGrid.Columns></DataGrid><Button Grid.Row="3" x:Name="ApplyReplaceButton" HorizontalAlignment="Right" Content="Apply Replace" Style="{StaticResource ApplyButtonStyle}" Click="ApplyReplaceButton_Click"/></Grid></TabItem>
<TabItem Header="Reports"><StackPanel Margin="10"><TextBlock x:Name="ReportsStatusTextBlock" Foreground="#7EC8FF" Margin="0,0,0,8"/><Button x:Name="ExportAuditCsvButton" Content="Export Audit Summary CSV" Click="ExportAuditCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="240" Margin="0,0,0,6"/><Button x:Name="ExportUnusedCsvButton" Content="Export Unused Filters CSV" Click="ExportUnusedCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="240" Margin="0,0,0,6"/><Button x:Name="ExportReplaceCsvButton" Content="Export Replace Preview CSV" Click="ExportReplaceCsvButton_Click" Style="{StaticResource ToolButtonStyle}" Width="240"/></StackPanel></TabItem>
</TabControl></Grid></Window>
