<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Manager Pro"
        Height="900" Width="1600" Background="#1E252B" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#1E252B"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#26303A"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#202931"/>
        <SolidColorBrush x:Key="BorderBrushBase" Color="#384754"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EAF1F5"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8C7D3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7EC8FF"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#0A84D6"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="#1A2229"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#2B3742"/>
        <SolidColorBrush x:Key="GridRowBrush" Color="#1F2A33"/>
        <SolidColorBrush x:Key="GridAltRowBrush" Color="#22303A"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#32414E"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#2E7FB8"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource AccentStrongBrush}"/>
            <Setter Property="BorderBrush" Value="#6FB8ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3D95D1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#266A99"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#33424F"/>
                                <Setter Property="Foreground" Value="#95A6B3"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#4A5C6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#1F2A33"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="2,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2F4B63"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2E7FB8"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <Border x:Name="ComboBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="26"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Margin="8,2,6,2"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                        <Border Grid.Column="1" Background="#22303A" BorderBrush="#3C4D5A" BorderThickness="1,0,0,0">
                                            <Path HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Fill="{StaticResource TextMutedBrush}"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#1A2229"
                                        BorderBrush="#465A6A"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#5E7B91"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4FB2FF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#202B35"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4FB2FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#95A6B3"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="#26313A"/>
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#445563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#C5D2DC"/>
            <Setter Property="Background" Value="#24313B"/>
            <Setter Property="BorderBrush" Value="#415262"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="TabBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4,4,0,0"/>
                            <Border x:Name="ActiveLine" Background="Transparent" Height="3" VerticalAlignment="Bottom" Margin="8,0,8,0"/>
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,4"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2F3E4A"/>
                                <Setter Property="Foreground" Value="#E5EEF5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#1B2D3E"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4FB2FF"/>
                                <Setter TargetName="ActiveLine" Property="Background" Value="#2FA6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SummaryCardBorder" TargetType="Border">
            <Setter Property="Background" Value="#1C2630"/>
            <Setter Property="BorderBrush" Value="#344656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource GridRowBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource GridRowBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAltRowBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource GridRowBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A3945"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" CornerRadius="6" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="HeaderLogoImage" Width="24" Height="24" Margin="0,0,8,0"/>
                    <TextBlock Text="FILTER MANAGER PRO - pyMENVIC" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="HeaderCardBorder1" Style="{StaticResource SummaryCardBorder}" Padding="8,6"><StackPanel><TextBlock x:Name="HeaderCardLabel1" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue1" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                    <Border x:Name="HeaderCardBorder2" Style="{StaticResource SummaryCardBorder}" Padding="8,6"><StackPanel><TextBlock x:Name="HeaderCardLabel2" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue2" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                    <Border x:Name="HeaderCardBorder3" Style="{StaticResource SummaryCardBorder}" Padding="8,6"><StackPanel><TextBlock x:Name="HeaderCardLabel3" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue3" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                    <Border x:Name="HeaderCardBorder4" Style="{StaticResource SummaryCardBorder}" Padding="8,6"><StackPanel><TextBlock x:Name="HeaderCardLabel4" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue4" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                    <Border x:Name="HeaderCardBorder5" Style="{StaticResource SummaryCardBorder}" Padding="8,6"><StackPanel><TextBlock x:Name="HeaderCardLabel5" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue5" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                    <Border x:Name="HeaderCardBorder6" Style="{StaticResource SummaryCardBorder}" Padding="8,6" Margin="0"><StackPanel><TextBlock x:Name="HeaderCardLabel6" Text="-" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/><TextBlock x:Name="HeaderCardValue6" Text="0" FontSize="17" FontWeight="Bold"/></StackPanel></Border>
                </WrapPanel>
            </Grid>
        </Border>
        <TabControl x:Name="MainTabControl" Grid.Row="2" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrushBase}" Foreground="{StaticResource TextPrimaryBrush}" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="Audit">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button x:Name="RefreshAuditButton" Style="{StaticResource ToolButtonStyle}" Content="Refresh Audit" Width="140" Click="RefreshAuditButton_Click"/>
                        <TextBlock Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}" Text="Categories show which Revit categories each filter applies to. They help identify comparable or duplicate filters." TextWrapping="Wrap"/>
                    </StackPanel>
                    <DataGrid x:Name="AuditGrid" Grid.Row="2" AutoGenerateColumns="False">
                        <DataGrid.Columns><DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="*"/><DataGridTextColumn Header="Categories" Binding="{Binding Categories}" Width="2*"/><DataGridTextColumn Header="Views" Binding="{Binding ViewCount}" Width="90"/><DataGridTextColumn Header="Templates" Binding="{Binding TemplateCount}" Width="90"/><DataGridTextColumn Header="Total Uses" Binding="{Binding TotalCount}" Width="90"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/></DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Rename / Standardize">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="6"/><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"><TextBlock Text="Prefix:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimaryBrush}"/><TextBox x:Name="RenamePrefixTextBox" Width="220" Height="28" Text=""/><Button x:Name="PreviewRenameButton" Style="{StaticResource ToolButtonStyle}" Content="Preview" Width="120" Margin="10,0,0,0" Click="PreviewRenameButton_Click"/></StackPanel>
                    <TextBlock x:Name="RenameStatusTextBlock" Grid.Row="2" Text="" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                    <DataGrid x:Name="RenameGrid" Grid.Row="4" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="Current Name" Binding="{Binding CurrentName}" Width="*"/><DataGridTextColumn Header="Proposed Name" Binding="{Binding ProposedName}" Width="*"/></DataGrid.Columns></DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Replace / Consolidate">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="6"/><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal"><TextBlock Text="Source:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/><ComboBox x:Name="SourceComboBox" Width="280" Margin="6,0,12,0" DisplayMemberPath="Name"/><TextBlock Text="Target:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/><ComboBox x:Name="TargetComboBox" Width="280" Margin="6,0,12,0" DisplayMemberPath="Name"/><Button x:Name="PreviewReplaceButton" Style="{StaticResource ToolButtonStyle}" Content="Preview Usage" Width="130" Click="PreviewReplaceButton_Click"/></StackPanel>
                    <TextBlock x:Name="ReplaceStatusTextBlock" Grid.Row="2" Text="" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                    <DataGrid x:Name="ReplaceGrid" Grid.Row="4" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="View / Template" Binding="{Binding ViewName}" Width="*"/><DataGridTextColumn Header="Type" Binding="{Binding ViewKind}" Width="140"/><DataGridTextColumn Header="Source Applied" Binding="{Binding HasSource}" Width="100"/><DataGridTextColumn Header="Target Applied" Binding="{Binding HasTarget}" Width="100"/></DataGrid.Columns></DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Reports">
                <Grid Margin="10"><Border Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" CornerRadius="5" Padding="12"><StackPanel><TextBlock Text="Reports are planned for a future release. Upcoming outputs: Audit Summary, Unused Filters, and Replace Impact snapshots." TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{StaticResource TextMutedBrush}"/><TextBlock Text="Planned exports will reuse active tab context and preserve current sorting and filters." TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{StaticResource TextMutedBrush}"/><Button Content="Copy Audit Summary (Coming Soon)" Style="{StaticResource ToolButtonStyle}" Width="240" HorizontalAlignment="Left" Margin="0,0,0,6" IsEnabled="False"/><Button Content="Export CSV (Coming Soon)" Style="{StaticResource ToolButtonStyle}" Width="240" HorizontalAlignment="Left" IsEnabled="False"/></StackPanel></Border></Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
