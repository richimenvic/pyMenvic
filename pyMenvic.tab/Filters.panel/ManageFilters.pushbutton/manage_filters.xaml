<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Filters"
        Height="900"
        Width="1600"
        MinHeight="760"
        MinWidth="1320"
        Background="#1E252B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel" Color="#26303A"/>
        <SolidColorBrush x:Key="BgPanelAlt" Color="#202931"/>
        <SolidColorBrush x:Key="BgInput" Color="#182028"/>
        <SolidColorBrush x:Key="Border" Color="#384754"/>
        <SolidColorBrush x:Key="TextHigh" Color="#EAF1F5"/>
        <SolidColorBrush x:Key="TextMed" Color="#A8BAC7"/>
        <SolidColorBrush x:Key="TextLow" Color="#708392"/>
        <SolidColorBrush x:Key="BtnPrimary" Color="#245D7C"/>
        <SolidColorBrush x:Key="BtnSuccess" Color="#2A6B3F"/>
        <SolidColorBrush x:Key="BtnDanger" Color="#6B3131"/>
        <SolidColorBrush x:Key="StatusReady" Color="#8ED59B"/>
        <SolidColorBrush x:Key="StatusWarn" Color="#F0A96E"/>
        <SolidColorBrush x:Key="StatusMuted" Color="#8B99A4"/>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextHigh}"/></Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style TargetType="ComboBox"><Setter Property="Height" Value="30"/><Setter Property="FontSize" Value="12"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource TextHigh}"/><Setter Property="FontSize" Value="12"/></Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource BtnPrimary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{StaticResource BtnSuccess}"/></Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{StaticResource BtnDanger}"/></Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="AlternatingRowBackground" Value="#23303A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21475D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Rename Pending"><Setter Property="Foreground" Value="#7DC6FF"/></DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Unused"><Setter Property="Foreground" Value="{StaticResource StatusReady}"/></DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Duplicate"><Setter Property="Foreground" Value="{StaticResource StatusWarn}"/></DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Duplicate + Unused"><Setter Property="Foreground" Value="{StaticResource StatusWarn}"/></DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Used"><Setter Property="Foreground" Value="{StaticResource StatusMuted}"/></DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal"><Image x:Name="HeaderLogoImage" Width="24" Height="24" Margin="0,0,8,0"/><TextBlock Text="MANAGE FILTERS - pyMENVIC" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                    <TextBlock Text="Review filter usage, find unused or duplicate filters, and purge selected unused filters." Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextLow}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="FILTERS" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="TotalText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="VISIBLE" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="VisibleText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="UNUSED" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="UnusedText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="#7DC487"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5"><StackPanel><TextBlock Text="DUPLICATES" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="DuplicateText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="#F0A96E"/></StackPanel></Border>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="16"/><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"><TextBlock Text="SEARCH" Style="{StaticResource LabelStyle}"/><TextBox x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="SCOPE" Style="{StaticResource LabelStyle}"/><ComboBox x:Name="ScopeComboBox" SelectionChanged="ScopeComboBox_SelectionChanged"/></StackPanel>
                <TextBlock Grid.Column="3" VerticalAlignment="Bottom" Margin="0,0,16,7" Foreground="{StaticResource TextLow}" Text="Review filters before deleting. Only unused filters can be purged."/>
                <Button Grid.Column="4" x:Name="RefreshButton" Width="120" Content="REFRESH" Click="RefreshButton_Click"/>
                <Button Grid.Column="6" x:Name="CheckVisibleButton" Width="140" Content="CHECK VISIBLE" Click="CheckVisibleButton_Click"/>
            </Grid>
        </Border>
        <Border Grid.Row="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Grid.Row="0"><TextBlock Text="PREVIEW" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Edit filter names here. Changed rows are checked automatically and can be saved with Save Renames." Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextLow}"/></StackPanel>
                <DataGrid x:Name="ResultsGrid" Grid.Row="2" AutoGenerateColumns="False" MouseDoubleClick="ResultsGrid_MouseDoubleClick" CellEditEnding="ResultsGrid_CellEditEnding" CurrentCellChanged="ResultsGrid_CurrentCellChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="APPLY" Width="58">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate><CheckBox IsChecked="{Binding Include, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" Focusable="False" Click="IncludeRowCheckBox_Click"/></DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="FILTER NAME" Binding="{Binding FilterName, Mode=TwoWay}" Width="*"/>
                        <DataGridTextColumn Header="VIEWS" Binding="{Binding UsedViewsCount}" Width="70"/>
                        <DataGridTextColumn Header="TEMPLATES" Binding="{Binding UsedTemplatesCount}" Width="88"/>
                        <DataGridTextColumn Header="TOTAL USES" Binding="{Binding TotalUses}" Width="84"/>
                        <DataGridTemplateColumn Header="STATUS" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate><TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}"/></DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="DUPLICATE TYPE" Binding="{Binding DuplicateTypeDisplay}" Width="130"/>
                        <DataGridTextColumn Header="DUPLICATE GROUP" Binding="{Binding DuplicateGroupDisplay}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <DockPanel Grid.Row="6" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{StaticResource TextLow}" Text="Edited names can be saved with Save Renames. Purge still deletes checked unused filters only."/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="SaveRenamesButton" Width="150" Content="SAVE RENAMES" Click="SaveRenamesButton_Click" Margin="0,0,14,0"/>
                <Button x:Name="PurgeButton" Width="150" Content="PURGE SELECTED" Style="{StaticResource SuccessButton}" Click="PurgeButton_Click"/>
                <Button x:Name="CloseButton" Width="110" Content="CLOSE" Style="{StaticResource DangerButton}" Click="CloseButton_Click" Margin="10,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
