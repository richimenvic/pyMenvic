<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace Filters"
        Height="920"
        Width="1680"
        MinHeight="760"
        MinWidth="1360"
        Background="#1E252B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel" Color="#26303A"/>
        <SolidColorBrush x:Key="BgPanelAlt" Color="#202931"/>
        <SolidColorBrush x:Key="BgInput" Color="#182028"/>
        <SolidColorBrush x:Key="Border" Color="#384754"/>
        <SolidColorBrush x:Key="TextHigh" Color="#EAF1F5"/>
        <SolidColorBrush x:Key="TextMed" Color="#A8BAC7"/>
        <SolidColorBrush x:Key="TextLow" Color="#708392"/>
        <SolidColorBrush x:Key="BtnPrimary" Color="#0A84D6"/>
        <SolidColorBrush x:Key="BtnSuccess" Color="#2A6B3F"/>
        <SolidColorBrush x:Key="BtnDanger" Color="#6B3131"/>
        <SolidColorBrush x:Key="StatusReady" Color="#8ED59B"/>
        <SolidColorBrush x:Key="StatusWarn" Color="#F0A96E"/>
        <SolidColorBrush x:Key="StatusMuted" Color="#8B99A4"/>
        <SolidColorBrush x:Key="StatusError" Color="#E68181"/>
        <SolidColorBrush x:Key="SourceGroup" Color="#324D60"/>
        <SolidColorBrush x:Key="SourceGroupSub" Color="#293F4F"/>
        <SolidColorBrush x:Key="TargetGroup" Color="#3A645A"/>
        <SolidColorBrush x:Key="TargetGroupSub" Color="#31564D"/>
        <SolidColorBrush x:Key="SourceCell" Color="#233847"/>
        <SolidColorBrush x:Key="TargetCell" Color="#24433C"/>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="1"/>
                    <Setter TargetName="ButtonBorder" Property="Background" Value="#249DF0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="ButtonBorder" Property="Background" Value="#086EB2"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#2A5F7D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#34789E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MaxDropDownHeight" Value="320"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,30,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="26"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="1" Background="Transparent">
                                                <Path Data="M 0 0 L 5 5 L 10 0"
                                                      Stroke="#A8BAC7"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource BgInput}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource BtnPrimary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnSuccess}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnDanger}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="AlternatingRowBackground" Value="#23303A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21475D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Ready">
                    <Setter Property="Foreground" Value="#84C690"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Merge">
                    <Setter Property="Foreground" Value="#CFA06A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Target exists">
                    <Setter Property="Foreground" Value="#CFA06A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                    <Setter Property="Foreground" Value="{StaticResource StatusMuted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Same filter">
                    <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="HeaderLogoImage" Width="24" Height="24" Margin="0,0,8,0"/>
                        <TextBlock Text="REPLACE FILTERS IN VIEWS - pyMENVIC" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Find where a filter is used in views and templates, then replace it while keeping graphics overrides."
                               Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextLow}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="FILTERS" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="TotalText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="ROWS" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="VisibleText" Text="0" FontSize="18" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0"><StackPanel><TextBlock Text="READY" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="ReadyText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="#7DC487"/></StackPanel></Border>
                    <Border Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5"><StackPanel><TextBlock Text="ISSUES" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="IssuesText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="#F0A96E"/></StackPanel></Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SOURCE FILTER" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="SourceFilterComboBox" SelectionChanged="FilterComboBox_SelectionChanged" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TARGET FILTER" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="TargetFilterComboBox" SelectionChanged="FilterComboBox_SelectionChanged" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <Button x:Name="RefreshButton" Width="130" Content="REFRESH" Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,7">
                        <CheckBox x:Name="IncludeViewsCheckBox" Content="INCLUDE VIEWS" Click="ScopeCheckBox_Click"/>
                    </Border>
                    <Border Grid.Column="2" Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,7">
                        <CheckBox x:Name="IncludeTemplatesCheckBox" Content="INCLUDE TEMPLATES" Click="ScopeCheckBox_Click"/>
                    </Border>
                    <Border Grid.Column="4" Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,7">
                        <CheckBox x:Name="MergeExistingCheckBox" Content="MERGE IF TARGET EXISTS" Click="ScopeCheckBox_Click"/>
                    </Border>
                    <Border Grid.Column="6" Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,7">
                        <CheckBox x:Name="CopyVisibilityCheckBox" Content="COPY SOURCE VISIBLE"/>
                    </Border>
                    <Border Grid.Column="8" Background="#1B232A" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,7">
                        <CheckBox x:Name="CopyEnabledCheckBox" Content="COPY SOURCE ACTIVE"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PREVIEW" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Sheet helps you see where each view is placed. Target Active and Target Visible can be edited directly when the target filter already exists."
                                   Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextLow}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="SEARCH" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,16,0,0">
                        <CheckBox x:Name="CheckAllRowsCheckBox" Content="CHECK ALL" Click="CheckAllRowsCheckBox_Click" Margin="0,0,6,0"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" BorderBrush="{StaticResource Border}" BorderThickness="1" Background="Transparent" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="98"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="98"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="1" Grid.Column="0" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="APPLY" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="VIEW" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="TYPE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="3" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="SHEET" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="4" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="View Template" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="9" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="STATUS" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="10" Background="#21475D" BorderBrush="#30414D" BorderThickness="0,0,1,0">
                            <TextBlock Text="MATCH" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="11" Background="#21475D">
                            <TextBlock Text="ACTION" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </Border>

                        <Grid Grid.Row="0" Grid.Column="5" Grid.ColumnSpan="2" Background="{StaticResource SourceGroup}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2" Background="{StaticResource SourceGroup}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,1">
                                <TextBlock Text="SOURCE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <Border Grid.Row="1" Grid.Column="5" Background="{StaticResource SourceGroupSub}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                                <TextBlock Text="ACTIVE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="6" Background="{StaticResource SourceGroupSub}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                                <TextBlock Text="VISIBLE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                        </Border>

                        <Grid Grid.Row="0" Grid.Column="7" Grid.ColumnSpan="2" Background="{StaticResource TargetGroup}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2" Background="{StaticResource TargetGroup}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,1">
                                <TextBlock Text="TARGET" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <Border Grid.Row="1" Grid.Column="7" Background="{StaticResource TargetGroupSub}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                                <TextBlock Text="ACTIVE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="8" Background="{StaticResource TargetGroupSub}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                                <TextBlock Text="VISIBLE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <DataGrid x:Name="ResultsGrid" Grid.Row="4" AutoGenerateColumns="False" HeadersVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="APPLY" Width="58" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Include, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              Click="IncludeRowCheckBox_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="VIEW" Binding="{Binding ViewName}" Width="220"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ViewKind}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="SHEET" Binding="{Binding SheetInfo}" Width="320" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="View Template" Binding="{Binding IsTemplate}" Width="96" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="" Width="98" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SourceCell}">
                                        <CheckBox IsChecked="{Binding SourceEnabled}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="False"
                                                  IsEnabled="False"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="100" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SourceCell}">
                                        <CheckBox IsChecked="{Binding SourceVisible}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="False"
                                                  IsEnabled="False"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="98" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource TargetCell}">
                                        <CheckBox IsChecked="{Binding TargetEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="False"
                                                  IsEnabled="{Binding AlreadyHasTarget}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="100" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource TargetCell}">
                                        <CheckBox IsChecked="{Binding TargetVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="False"
                                                  IsEnabled="{Binding AlreadyHasTarget}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="88" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="MATCH" Binding="{Binding Match}" Width="96" IsReadOnly="True"/>
                        <DataGridTextColumn Header="ACTION" Binding="{Binding Action}" Width="96" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="6" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{StaticResource TextLow}" Text="Replace the source filter with the target only on ready rows. Existing target values can be edited directly in the grid before you apply."/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="ApplyButton" Width="120" Content="REPLACE" Style="{StaticResource SuccessButton}" Click="ApplyButton_Click"/>
                <Button x:Name="CloseButton" Width="110" Content="CLOSE" Style="{StaticResource DangerButton}" Click="CloseButton_Click" Margin="10,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
