<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Manager Pro"
        Height="900" Width="1600" Background="#1E252B" WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#26303A" BorderBrush="#384754" BorderThickness="1" CornerRadius="6" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="HeaderLogoImage" Width="24" Height="24" Margin="0,0,8,0"/>
                <TextBlock Text="FILTER MANAGER PRO - pyMENVIC" FontSize="18" FontWeight="SemiBold" Foreground="#EAF1F5"/>
            </StackPanel>
        </Border>
        <TabControl Grid.Row="2" Background="#202931" BorderBrush="#384754" Foreground="#EAF1F5">
            <TabItem Header="Audit">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Button x:Name="RefreshAuditButton" Content="Refresh Audit" Height="30" Width="140" Click="RefreshAuditButton_Click"/>
                    <DataGrid x:Name="AuditGrid" Grid.Row="2" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="*"/>
                            <DataGridTextColumn Header="Views" Binding="{Binding ViewCount}" Width="90"/>
                            <DataGridTextColumn Header="Templates" Binding="{Binding TemplateCount}" Width="90"/>
                            <DataGridTextColumn Header="Total Uses" Binding="{Binding TotalCount}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Rename / Standardize">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Prefix:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="RenamePrefixTextBox" Width="220" Height="28" Text=""/>
                        <Button x:Name="PreviewRenameButton" Content="Preview" Width="120" Height="30" Margin="10,0,0,0" Click="PreviewRenameButton_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="RenameGrid" Grid.Row="2" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Current Name" Binding="{Binding CurrentName}" Width="*"/>
                            <DataGridTextColumn Header="Proposed Name" Binding="{Binding ProposedName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Replace / Consolidate">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Source:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SourceComboBox" Width="280" Margin="6,0,12,0"/>
                        <TextBlock Text="Target:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TargetComboBox" Width="280" Margin="6,0,12,0"/>
                        <Button x:Name="PreviewReplaceButton" Content="Preview Usage" Width="130" Height="30" Click="PreviewReplaceButton_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="ReplaceGrid" Grid.Row="2" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="View / Template" Binding="{Binding ViewName}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding ViewKind}" Width="140"/>
                            <DataGridTextColumn Header="Source Applied" Binding="{Binding HasSource}" Width="100"/>
                            <DataGridTextColumn Header="Target Applied" Binding="{Binding HasTarget}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Reports">
                <Grid Margin="10">
                    <TextBlock Text="Reports export is not implemented yet. This tab is reserved for CSV/JSON outputs in a future iteration." TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
