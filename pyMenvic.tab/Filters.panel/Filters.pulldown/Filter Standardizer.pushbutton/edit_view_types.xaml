<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit View Types - pyMENVIC"
        Height="560"
        Width="980"
        MinHeight="460"
        MinWidth="760"
        Background="#1E252B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel" Color="#26303A"/>
        <SolidColorBrush x:Key="BgPanelAlt" Color="#202931"/>
        <SolidColorBrush x:Key="Border" Color="#384754"/>
        <SolidColorBrush x:Key="TextHigh" Color="#EAF1F5"/>
        <SolidColorBrush x:Key="TextMed" Color="#A8BAC7"/>
        <SolidColorBrush x:Key="TextLow" Color="#708392"/>
        <SolidColorBrush x:Key="BtnPrimary" Color="#245D7C"/>
        <SolidColorBrush x:Key="BtnSuccess" Color="#2A6B3F"/>
        <SolidColorBrush x:Key="BtnDanger" Color="#6B3131"/>
        <SolidColorBrush x:Key="StatusReady" Color="#8ED59B"/>
        <SolidColorBrush x:Key="StatusBlocked" Color="#F0A96E"/>
        <SolidColorBrush x:Key="StatusError" Color="#E68181"/>
        <SolidColorBrush x:Key="StatusMuted" Color="#8B99A4"/>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="#182028"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="#182028"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ComboItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#2A5F7D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ComboItemBorder" Property="Background" Value="#34789E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="#182028"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MaxDropDownHeight" Value="260"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,30,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="26"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="1" Background="Transparent">
                                                <Path Data="M 0 0 L 5 5 L 10 0"
                                                      Stroke="#A8BAC7"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#182028"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource BtnPrimary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnSuccess}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnDanger}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="AlternatingRowBackground" Value="#23303A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21475D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Ready">
                    <Setter Property="Foreground" Value="{StaticResource StatusReady}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Conflict">
                    <Setter Property="Foreground" Value="{StaticResource StatusBlocked}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Duplicate">
                    <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Empty">
                    <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="No change">
                    <Setter Property="Foreground" Value="{StaticResource StatusMuted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Unchecked">
                    <Setter Property="Foreground" Value="{StaticResource StatusMuted}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="EDIT VIEW TYPES" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Edita nombres reales de View Types. Solo filas Ready se aplican."
                               Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextLow}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TOTAL" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TotalTypesText" Text="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,18,0"/>
                    <TextBlock Text="VISIBLE" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="VisibleTypesText" Text="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,18,0"/>
                    <TextBlock Text="READY" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ReadyTypesText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource StatusReady}" Margin="0,0,18,0"/>
                    <TextBlock Text="ISSUES" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="IssueTypesText" Text="0" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource StatusBlocked}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SEARCH TYPE" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="SearchTypesTextBox" TextChanged="SearchTypesTextBox_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="VIEW FAMILY" Foreground="{StaticResource TextMed}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ViewFamilyFilterComboBox" SelectionChanged="ViewFamilyFilterComboBox_SelectionChanged"/>
                    </StackPanel>
                    <Button x:Name="CheckChangedTypesButton"
                            Grid.Column="4"
                            Width="125"
                            Content="CHECK EDITED"
                            VerticalAlignment="Bottom"
                            Click="CheckChangedTypesButton_Click"/>
                </Grid>
                <DataGrid x:Name="ViewTypesGrid"
                          Grid.Row="4"
                          AutoGenerateColumns="False"
                          CellEditEnding="ViewTypesGrid_CellEditEnding">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="APPLY" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Include, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Click="ViewTypeApplyCheckBox_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="VIEW FAMILY" Binding="{Binding ViewFamilyName}" Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="TYPE NAME" Binding="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTemplateColumn Header="RESET" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="RESET"
                                            Height="22"
                                            Padding="8,0"
                                            FontSize="10"
                                            Click="ResetTypeButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{StaticResource BtnDanger}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="No change">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                        <Setter Property="Background" Value="#3A4650"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="130" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="Only Ready rows will be renamed."
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextLow}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="ValidateTypesButton" Width="100" Content="VALIDATE" Background="#314A5A" Click="ValidateTypesButton_Click"/>
                <Button x:Name="ApplyTypesButton" Width="125" Content="APPLY" Style="{StaticResource SuccessButton}" Click="ApplyTypesButton_Click" Margin="10,0,0,0"/>
                <Button x:Name="CloseTypesButton" Width="110" Content="CLOSE" Style="{StaticResource DangerButton}" Click="CloseTypesButton_Click" Margin="10,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>


