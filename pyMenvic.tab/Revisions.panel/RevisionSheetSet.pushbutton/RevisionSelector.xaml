<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Revisions"
        Width="760"
        Height="744"
        MinWidth="640"
        MinHeight="644"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#1E252B"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#26303A"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#2F4B5E"/>
        <SolidColorBrush x:Key="SurfaceBgBrush" Color="#1F2B35"/>
        <SolidColorBrush x:Key="ListSurfaceBgBrush" Color="#26303A"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="#1F2B35"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#344B5B"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8FA7BA"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#2F4B5E"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#26303A"/>
        <SolidColorBrush x:Key="PrimaryButtonBgBrush" Color="#2D9D55"/>
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#49B571"/>

        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/></Style>
        <Style TargetType="TextBox"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Setter Property="Background" Value="{DynamicResource InputBgBrush}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/></Style>
        <Style TargetType="ListBox"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/></Style>
        <Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/></Style>
        <Style TargetType="RadioButton"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Margin" Value="0,0,0,6"/></Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="HorizontalContentAlignment" Value="Center"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Padding" Value="12,0"/><Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True"><Grid><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/></Grid></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"><Setter Property="Background" Value="{DynamicResource PrimaryButtonBgBrush}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/><Setter Property="Foreground" Value="White"/></Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="16,16,16,10">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Image x:Name="HeaderLogoImage" Grid.Column="0" Width="28" Height="28" Margin="0,0,10,0" VerticalAlignment="Top"/><StackPanel Grid.Column="1"><TextBlock Text="REVISION SHEET SET - pyMENVIC" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Select revisions, filter the list, and choose how sheets should match before creating the set." Margin="0,3,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/></StackPanel></Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0"><TextBlock x:Name="lblSearch" Text="Search revisions" Margin="0,0,0,3" FontWeight="SemiBold"/><Grid><TextBox x:Name="txtSearch" Height="32" Padding="10,5" BorderThickness="1"/><TextBlock x:Name="searchPlaceholder" Margin="12,7,0,0" VerticalAlignment="Top" Foreground="{DynamicResource TextSecondaryBrush}" IsHitTestVisible="False" Text="Type to filter revisions..."/></Grid></StackPanel>
            <StackPanel Grid.Column="1" Margin="14,0,0,0"><TextBlock x:Name="lblMode" Text="Match mode" Margin="0,0,0,3" FontWeight="SemiBold"/><Border Background="{DynamicResource InputBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,6"><StackPanel Orientation="Vertical"><RadioButton x:Name="rbMatchAll" Content="Matching ALL revisions" GroupName="MatchMode" IsChecked="True"/><RadioButton x:Name="rbMatchAny" Content="Matching ANY revision" GroupName="MatchMode" Margin="0"/></StackPanel></Border><TextBlock x:Name="lblModeHelp" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="ALL = sheets containing all selected revisions. ANY = sheets containing at least one selected revision."/></StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="lblRevisions" Grid.Column="0" Text="Available revisions" FontWeight="SemiBold"/><TextBlock x:Name="lblStatus" Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Text="Selected: 0 | Visible: 0 | Total: 0"/></Grid>

        <Border Grid.Row="3" Background="{DynamicResource ListSurfaceBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8" Margin="16,0,16,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="6"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid Grid.Row="0"><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Grid.Column="1" Text="No." FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/><TextBlock Grid.Column="2" Text="Description" FontWeight="SemiBold" Margin="1,0,0,0" HorizontalAlignment="Left" Foreground="{DynamicResource TextSecondaryBrush}"/><TextBlock Grid.Column="3" Text="Date" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/></Grid><ListBox x:Name="lstRevisions" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" FontSize="14"/></Grid>
        </Border>

        <Grid Grid.Row="5" Margin="16,8,16,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="0.55*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1.25*"/></Grid.ColumnDefinitions><Button x:Name="btnSelectVisible" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="Select Visible" Height="36" MinWidth="120"/><Button x:Name="btnClearVisible" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Content="Clear Visible" Height="36" MinWidth="120"/><Button x:Name="btnInvertVisible" Grid.Column="4" Style="{StaticResource SecondaryButtonStyle}" Content="Invert Visible" Height="36" MinWidth="120"/><Button x:Name="btnCancel" Grid.Column="7" Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Height="36" MinWidth="120"/><Button x:Name="btnCreate" Grid.Column="9" Style="{StaticResource PrimaryButtonStyle}" Content="Create Sheet Set" Height="38" MinWidth="170" FontWeight="SemiBold"/></Grid>

        <Border Grid.Row="6" Background="#11161B" BorderThickness="0" Padding="16,8" Margin="0,8,0,0">
            <TextBlock x:Name="FooterVersionTextBlock" Text="pyMENVIC Revision Sheet Set | MVP 0.3.39" Foreground="#A9BAC8" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
