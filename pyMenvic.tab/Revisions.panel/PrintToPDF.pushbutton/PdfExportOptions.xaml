<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Export Options" Height="500" Width="620"
        ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFF7F7F7"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Native PDF Export"
                           FontSize="15"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Use the active Revit PDF Export Setup as the base, then optionally apply the custom options below."
                           Foreground="#FF666666"
                           TextWrapping="Wrap"
                           Margin="0,4,0,8"/>
                <Border Background="#FFFFFFFF"
                        BorderBrush="#FFD9D9D9"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8">
                    <CheckBox x:Name="enableoverrides_cb"
                              Content="Apply custom PDF settings"
                              FontWeight="SemiBold"
                              Click="update_offset_state"/>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Colors, Orientation, Zoom, and Paper Size still come from the active Revit PDF Export Setup."
                           TextWrapping="Wrap"
                           Foreground="#FF666666"
                           Margin="0,0,0,8"/>

                <Border BorderBrush="#FFD9D9D9"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,10">
                    <Grid x:Name="options_panel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Paper Placement"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="paperplacement_center_rb"
                                             GroupName="PaperPlacement"
                                             Content="Center"
                                             IsChecked="True"
                                             Click="update_offset_state"/>
                                <RadioButton x:Name="paperplacement_offset_rb"
                                             GroupName="PaperPlacement"
                                             Content="Offset From Corner"
                                             Margin="12,0,0,0"
                                             Click="update_offset_state"/>
                            </StackPanel>

                            <TextBlock x:Name="offsets_lbl"
                                       Text="Offsets (mm)"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="offsetx_tb" Width="72" Margin="0,0,6,0"/>
                                <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="offsety_tb" Width="72" Margin="0,0,6,0"/>
                                <TextBlock Text="Y" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Output Type"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <StackPanel Margin="0,0,0,10">
                                <RadioButton x:Name="usevector_rb"
                                             GroupName="OutputType"
                                             Content="Vector (automatic when possible)"
                                             IsChecked="True"/>
                                <RadioButton x:Name="useraster_rb"
                                             GroupName="OutputType"
                                             Content="Raster"
                                             Margin="0,6,0,0"/>
                            </StackPanel>

                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Raster Quality"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <ComboBox x:Name="rasterquality_cb" Width="150" SelectedIndex="2">
                                    <ComboBoxItem Content="Low"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Presentation"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <GroupBox Header="Options">
                    <Grid Margin="10,8,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="viewlinksinblue_cb" Content="View links in blue"/>
                            <CheckBox x:Name="hiderefplanes_cb" Content="Hide ref/work planes" Margin="0,6,0,0"/>
                            <CheckBox x:Name="hideunrefviewtags_cb" Content="Hide unreferenced view tags" Margin="0,6,0,0"/>
                            <CheckBox x:Name="maskcoincident_cb" Content="Region edges mask coincident lines" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <CheckBox x:Name="hidescopeboxes_cb" Content="Hide scope boxes"/>
                            <CheckBox x:Name="hidecropboundaries_cb" Content="Hide crop boundaries" Margin="0,6,0,0"/>
                            <CheckBox x:Name="replacehalftone_cb" Content="Replace halftone with thin lines" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
            <Button Content="Cancel" Width="90" Margin="0,0,10,0" Click="cancel"/>
            <Button Content="Save" Width="90" Click="save"/>
        </DockPanel>
    </Grid>
</Window>
