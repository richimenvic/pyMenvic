<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title}" Height="760" Width="1460" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen" HorizontalContentAlignment="Center">
    <Window.Resources>
        <SolidColorBrush x:Key="RevBGColor" Color="#FFEEEEEE"/>

        <Style x:Key="IndexColumnStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="{DynamicResource pyRevitAccentBrush}"/>
        </Style>

        <Style x:Key="DefaultColumnStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="ToolTip" Value="{Binding tooltip}"/>
            <Setter Property="ContextMenu" Value="{DynamicResource ItemContextMenu}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding printable}" Value="False">
                    <Setter Property="Foreground" Value="#bdbdbd" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="Default" TargetType="{x:Type DataGridCell}">
            <StackPanel Background="White">
                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                      Columns="{TemplateBinding GridView.ColumnCollection}"/>
            </StackPanel>

        </ControlTemplate>

        <ControlTemplate x:Key="NonPrintableSheet" TargetType='{x:Type DataGridCell}'>
            <StackPanel Background="#f6f6f6">
                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                          Columns="{TemplateBinding GridView.ColumnCollection}"/>
            </StackPanel>
        </ControlTemplate>

        <DataTemplate x:Key="RevisionCell">
            <StackPanel x:Name="revinfo" VerticalAlignment="Center" Orientation="Horizontal">
                <Border Background="{StaticResource RevBGColor}" CornerRadius="3,0,0,3" MinWidth="16" Margin="2,2,0,2" Padding="5,0,5,0">
                    <TextBlock Text="{Binding revision.date}" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="{StaticResource RevBGColor}" MinWidth="16" Margin="0,2,0,2" Padding="5,0,5,0" BorderBrush="LightGray" BorderThickness="1,0,1,0">
                    <TextBlock Text="{Binding revision.number}" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Border>
                <Border Background="{StaticResource RevBGColor}" CornerRadius="0,3,3,0" MinWidth="16" Padding="5,0,5,0" Margin="0,2,0,2">
                    <TextBlock Text="{Binding revision.desc}" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding revision.is_set}" Value="False">
                    <Setter TargetName="revinfo" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="PrintSettingCell">
            <StackPanel x:Name="psettinginfo" VerticalAlignment="Center" Orientation="Horizontal">
                <Border Background="{StaticResource RevBGColor}" CornerRadius="3" Margin="2,2,0,2" Padding="5,0,5,0">
                    <TextBlock x:Name="psettingname" Text="{Binding print_settings.Name}" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding read_only}" Value="True">
                    <Setter TargetName="psettingname" Property="Foreground" Value="Gray" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="TextBlock.TextDecorations" Value="{x:Null}" />
        </Style>

        <Canvas x:Key="printIcon">
            <Path Canvas.Top="-18" Canvas.Left="-18"
                  Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z"
                  Fill="Black">
                <Path.LayoutTransform>
                    <ScaleTransform ScaleX="1.5"  ScaleY="1.5"/>
                </Path.LayoutTransform>
            </Path>
        </Canvas>

        <DataTemplate x:Key="printSettingsItem">
            <WrapPanel>
                <TextBlock x:Name="sizeName" Text="{Binding name}" />
                <Border x:Name="incompatibleMarker" Background="Red"  Height="18" Margin="8,0,0,0" CornerRadius="3">
                    <TextBlock HorizontalAlignment="Left" Padding="5" Text="{DynamicResource IncompatibleWithPrinter}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                </Border>
            </WrapPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding is_compatible}" Value="True">
                    <Setter TargetName="incompatibleMarker" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="sizeName" Property="Foreground" Value="Black" />
                </DataTrigger>
                <DataTrigger Binding="{Binding is_compatible}" Value="False">
                    <Setter TargetName="incompatibleMarker" Property="Visibility" Value="Visible" />
                    <Setter TargetName="sizeName" Property="Foreground" Value="Gray" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <DockPanel>
        <StackPanel Margin="10,6,10,0" DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <DockPanel Height="22">
                        <Grid Margin="0,0,10,0">
                            <Polygon Points="0,0 140,0 150,12 140,24 0,24"  Fill="{DynamicResource pyRevitDarkBrush}" SnapsToDevicePixels="True"/>
                            <TextBlock Text="{DynamicResource Model}" FontWeight="Medium" VerticalAlignment="Center" Margin="10,0,10,0" Foreground="White"/>
                        </Grid>
                        <ComboBox x:Name="documents_cb" SelectionChanged="doclist_changed" VerticalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock x:Name="docname" Text="{Binding name}" />
                                        <TextBlock x:Name="docname_linked" Visibility="Collapsed">
                                            <Run Text="{DynamicResource LinkedPrefix}"/>
                                            <Run Text="{Binding name}"/>
                                        </TextBlock>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding linked}" Value="True">
                                            <Setter TargetName="docname" Property="Visibility" Value="Hidden" />
                                            <Setter TargetName="docname_linked" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Height="22" Margin="0,4,0,0">
                        <Grid Margin="0,0,10,0">
                            <Polygon Points="0,0 140,0 150,12 140,24 0,24" Fill="{DynamicResource pyRevitDarkBrush}" SnapsToDevicePixels="True" />
                            <TextBlock Text="{DynamicResource SheetIndex}" FontWeight="Medium" VerticalAlignment="Center" Margin="10,0,10,0" Foreground="White"/>
                        </Grid>
                        <ComboBox x:Name="schedules_cb" SelectionChanged="sheetlist_changed" VerticalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding name}" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>
                </StackPanel>
                <Button x:Name="print_b" Grid.Column="1" Content="{StaticResource printIcon}" Margin="8,0,0,0" Padding="0" Click="print_sheets"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>
                <GroupBox Header="{DynamicResource SheetOrdering}" Grid.Column="0" Margin="0,4,5,0" Padding="5">
                    <StackPanel>
                        <CheckBox x:Name="reverse_cb" IsChecked="False" Click="options_changed" Content="{DynamicResource ReversePrintOrder}"/>
                        <StackPanel x:Name="order_sp" Margin="0,2,0,0">
                            <CheckBox x:Name="placeholder_cb" IsChecked="True" Click="options_changed" Content="{DynamicResource ShowNonPrintableSheets}"/>
                            <CheckBox x:Name="indexspace_cb" Margin="0,2,0,0" IsChecked="True" Click="options_changed" Content="{DynamicResource IncludeNonPrintableInIndexing}"/>
                            <Grid Margin="0,1,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" Height="28" Margin="0,1,0,0">
                                    <TextBlock Text="{DynamicResource IndexDigits}" Width="80" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                    <Slider x:Name="index_slider" Margin="10,0,0,0"
                                            Minimum="3" Maximum="6" TickPlacement="TopLeft" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                            ValueChanged="options_changed"/>
                                </DockPanel>
                                <DockPanel Grid.Column="2" Height="28" Margin="0,1,0,0">
                                    <TextBlock Text="{DynamicResource IndexStart}" Width="70" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    <Button Content="{DynamicResource Reset}" Width="50" DockPanel.Dock="Right"
                                            BorderThickness="0,1,1,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                            Click="rest_index" />
                                    <TextBox x:Name="indexstart_tb" Text="0" Margin="10,0,0,0" VerticalContentAlignment="Center" Padding="5,0,0,0"
                                             PreviewTextInput="validate_index_start" TextChanged="options_changed"/>
                                </DockPanel>
                            </Grid>
                            <DockPanel Margin="0,4,0,0" Height="20">
                                <TextBlock Text="{DynamicResource SheetLookup}" Width="80"  VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                <TextBox x:Name="sheetsearch_tb" Text="" Margin="10,0,0,0" VerticalContentAlignment="Center" Padding="5,0,5,0" TextChanged="sheet_search_changed"/>
                            </DockPanel>
                            <Expander Margin="0,4,0,0"
                                      IsExpanded="False"
                                      Header="{DynamicResource QuickGuide}">
                                <Border Padding="8,6,8,6"
                                        Background="#FFF7F7F7"
                                        BorderBrush="#FFD9D9D9"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBlock Text="{DynamicResource QuickGuideText}"
                                               Foreground="#FF666666"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="{DynamicResource SheetPrinting}" Grid.Column="1" Margin="0,4,5,0" Padding="5">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">

                        <Border Margin="0,0,0,5"
                                Padding="8,6,8,6"
                                Background="#FFF7F7F7"
                                BorderBrush="#FFD9D9D9"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="230"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="combine_cb"
                                        Grid.Column="0"
                                        IsChecked="False"
                                        IsEnabled="True"
                                        VerticalAlignment="Center"
                                        Checked="options_changed"
                                        Unchecked="options_changed"
                                        Content="{DynamicResource CombineIntoOnePDF}"/>
                                <DockPanel Grid.Column="1" Height="26" LastChildFill="False">
                                    <TextBlock Text="{DynamicResource ExportFormat}"
                                            Width="92"
                                            TextAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0"/>
                                    <ComboBox x:Name="exportformat_cb"
                                            Width="120"
                                            MinHeight="26"
                                            VerticalAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            SelectionChanged="options_changed"/>
                                </DockPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,3,0,0"
                                Padding="8,7,8,7"
                                Background="#FFF7F7F7"
                                BorderBrush="#FFD9D9D9"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource OutputSection}"
                                           FontWeight="SemiBold"
                                           Foreground="#FF304256"
                                           Margin="0,0,0,4"/>
                                <DockPanel x:Name="namingformat_dp" Height="26">
                                    <TextBlock Text="{DynamicResource NamingFormat}" Width="96" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="{DynamicResource EditFormats}" DockPanel.Dock="Right" Width="104" MinHeight="26" BorderThickness="0,1,1,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Click="edit_formats"/>
                                    <ComboBox x:Name="namingformat_cb" FontFamily="Consolas" MinHeight="26" VerticalContentAlignment="Center" SelectionChanged="options_changed">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Padding="5,1,5,1">
                                                        <TextBlock Text="{Binding name}">
                                                            <TextBlock.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="{DynamicResource CopyNamingFormat}"
                                                                              Click="copy_naming_format"/>
                                                                </ContextMenu>
                                                            </TextBlock.ContextMenu>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DockPanel>

                                <DockPanel Margin="0,4,0,0" Height="26" LastChildFill="True">
                                    <TextBlock Text="{DynamicResource OutputFolder}" Width="96" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="{DynamicResource Browse}" DockPanel.Dock="Right" Width="74" MinHeight="26" Margin="10,0,0,0" Click="pick_output_folder"/>
                                    <TextBox x:Name="folder_tb" MinHeight="26" VerticalContentAlignment="Center" Padding="5,0,5,0"/>
                                </DockPanel>

                                <DockPanel Margin="0,4,0,0" Height="26">
                                    <TextBlock Text="{DynamicResource FileName}" Width="96" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="filename_tb"
                                            MinHeight="26"
                                            VerticalContentAlignment="Center"
                                            Padding="5,0,5,0"
                                            ToolTip="{DynamicResource FileNameToolTip}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,5,0,0"
                                Padding="8,7,8,7"
                                Background="#FFF7F7F7"
                                BorderBrush="#FFD9D9D9"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource DeviceSection}"
                                           FontWeight="SemiBold"
                                           Foreground="#FF304256"
                                           Margin="0,0,0,4"/>
                                <DockPanel Height="26">
                                    <TextBlock Text="{DynamicResource Printer}" Width="96" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="printers_cb" MinHeight="26" SelectionChanged="printers_changed"/>
                                </DockPanel>

                                <DockPanel Margin="0,4,0,0" Height="26">
                                    <TextBlock Text="{DynamicResource PageSettings}" Width="96" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="printsettings_cb"
                                            MinHeight="26"
                                            SelectionChanged="sheetlist_changed"
                                            ItemTemplate="{StaticResource printSettingsItem}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,5,0,0"
                                Padding="8,7,8,7"
                                Background="#FFF9FCFF"
                                BorderBrush="{DynamicResource pyRevitAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="138"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource PdfOutputSection}"
                                               FontWeight="SemiBold"
                                               Foreground="#FF304256"/>
                                    <TextBlock x:Name="outputmode_tb"
                                               Text="{DynamicResource OutputModeUnknown}"
                                               Foreground="#FF555555"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button x:Name="pdfoptions_b"
                                        Grid.Column="1"
                                        Width="114"
                                        Height="28"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"
                                        Content="{DynamicResource PdfOptions}"
                                        Click="edit_pdf_options"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </DockPanel>
            </GroupBox>
            </Grid>
            <StackPanel VerticalAlignment="Center" Margin="0,8,0,4">
                <DockPanel LastChildFill="False" Margin="0,4,0,6" MinHeight="36" VerticalAlignment="Center">
                    <TextBlock TextWrapping="WrapWithOverflow"
                               DockPanel.Dock="Left"
                               Text="{DynamicResource ListOfSheets}"
                               VerticalAlignment="Center"
                               Height="26"
                               FontWeight="SemiBold">
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="{DynamicResource MoveToTop}" Width="95" Height="26" Margin="0,0,5,0" Click="move_to_top"/>
                        <Button Content="{DynamicResource MoveUp}" Width="80" Height="26" Margin="0,0,5,0" Click="move_up"/>
                        <Button Content="{DynamicResource MoveDown}" Width="80" Height="26" Margin="0,0,5,0" Click="move_down"/>
                        <Button Content="{DynamicResource ResetToStandard}" Width="120" Height="26" Margin="0,0,5,0" Click="reset_to_standard"/>
                        <Button Content="{DynamicResource SortBySheetNumber}" Width="145" Height="26" Margin="0,0,5,0" Click="sort_by_sheet_number"/>
                        <Button Content="{DynamicResource AddSheets}" Width="95" Height="26" Margin="0,0,5,0" Click="add_sheets"/>
                        <Button Content="{DynamicResource RemoveSelected}" Width="120" Height="26" Margin="0,0,5,0" Click="remove_selected"/>
                        <Button Content="{DynamicResource SaveCurrentSet}" Width="120" Height="26" Click="save_current_set"/>
                    </StackPanel>
                </DockPanel>
                <Border x:Name="errormsg_block" Background="Red" Padding="5" Margin="0,5,0,5" Visibility="Collapsed">
                    <TextBlock x:Name="errormsg_tb" Foreground="White" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="varsizeguide" Padding="5" Background="{DynamicResource pyRevitAccentBrush}" CornerRadius="3" Margin="0,5,0,5" Visibility="Collapsed">
                    <DockPanel DockPanel.Dock="Right">
                        <DockPanel x:Name="sheetopts_wp" DockPanel.Dock="Right" IsEnabled="False">
                            <DockPanel DockPanel.Dock="Bottom">
                                <Button DockPanel.Dock="Right" Height="25" Width="120" Margin="10,0,0,0" Content="{DynamicResource SetPrintSettings}" Click="set_sheet_printsettings"/>
                                <Button DockPanel.Dock="Left" Height="25" Width="120" Content="{DynamicResource ResetPrintSettings}" Click="sheetlist_changed"/>
                            </DockPanel>
                            <Grid />
                        </DockPanel>
                        <Expander Header="{DynamicResource Guide}" Foreground="White" Cursor="Help">
                            <TextBlock Margin="5,5,0,0" TextWrapping="Wrap" Foreground="White" Text="{DynamicResource VariablePaperGuideText}">
                            </TextBlock>
                        </Expander>
                    </DockPanel>
                </Border>
            </StackPanel>
        </StackPanel>
        <StatusBar DockPanel.Dock="Bottom" Height="25" Background="{DynamicResource pyRevitDarkBrush}">
            <TextBlock Foreground="#ffffff" Margin="10,0,0,0" Text="{DynamicResource StatusTitle}"/>
        </StatusBar>
        <DataGrid x:Name="sheets_lb"
                  AutoGenerateColumns="False"
                  Margin="10,0,10,10"
                  BorderThickness="1"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="30"
                  RowHeaderWidth="0"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  HorizontalGridLinesBrush="#dedede"
                  VerticalGridLinesBrush="#dedede"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  SelectionChanged="sheet_selection_changed">
            <DataGrid.Resources>
                <ContextMenu x:Key="ItemContextMenu">
                    <MenuItem  Header="{DynamicResource CopySheetFileNames}" Click="copy_filenames" />
                </ContextMenu>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Height" Value="30" />
                    <Setter Property="Background" Value="#FFF3F5F7" />
                    <Setter Property="Foreground" Value="#FF1F2D3D" />
                    <Setter Property="BorderBrush" Value="#FFD6DDE5" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="8,0,8,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource PrintIndex}" Binding="{Binding print_index}" MinWidth="70" Width="70" IsReadOnly="True" CellStyle="{StaticResource IndexColumnStyle}"/>
                <DataGridTextColumn Header="{DynamicResource SheetNumber}" Binding="{Binding number}" MinWidth="100" Width="100" IsReadOnly="True" CellStyle="{StaticResource DefaultColumnStyle}"/>
                <DataGridTextColumn Header="{DynamicResource SheetName}" Binding="{Binding name}" MinWidth="400" Width="400" IsReadOnly="True" CellStyle="{StaticResource DefaultColumnStyle}"/>
                <DataGridTemplateColumn Header="{DynamicResource Revision}" MinWidth="50" Width="1*" IsReadOnly="True"
                                        CellTemplate="{StaticResource RevisionCell}" SortMemberPath="revision_date_sortable" />
                <DataGridTemplateColumn x:Name="psettingcol" Header="{DynamicResource PrintSetting}" MinWidth="50" Width="*" IsReadOnly="True"
                                        CellTemplate="{StaticResource PrintSettingCell}" Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="pfilename" Header="{DynamicResource FileName}" FontFamily="Consolas" Binding="{Binding print_filename}"
                                    MinWidth="50" Width="2*" IsReadOnly="True" CellStyle="{StaticResource DefaultColumnStyle}" Visibility="Collapsed"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
