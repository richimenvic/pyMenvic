<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Type Standardizer"
        Height="930"
        Width="1510"
        MinHeight="800"
        MinWidth="1250"
        Background="#1E252B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- ============================================================
             COLOR TOKENS - pyMENVIC UI STANDARD
        ============================================================ -->
        <SolidColorBrush x:Key="BgApp"           Color="#1E252B"/>
        <SolidColorBrush x:Key="BgHeader"        Color="#26303A"/>
        <SolidColorBrush x:Key="BgContent"       Color="#F4F6F8"/>
        <SolidColorBrush x:Key="BgInput"         Color="#F7F9FB"/>
        <SolidColorBrush x:Key="BgCard"          Color="#1F2B35"/>
        <SolidColorBrush x:Key="BgCardAlt"       Color="#24323E"/>
        <SolidColorBrush x:Key="BgRow"           Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgRowAlt"        Color="#F0F3F6"/>
        <SolidColorBrush x:Key="BgRowHover"      Color="#DCE7EF"/>
        <SolidColorBrush x:Key="BgSelection"     Color="#0A70B8"/>
        <SolidColorBrush x:Key="BgMetric"        Color="#1F2B35"/>

        <SolidColorBrush x:Key="BorderSubtle"    Color="#C8D1D8"/>
        <SolidColorBrush x:Key="BorderMedium"    Color="#9FB3C1"/>
        <SolidColorBrush x:Key="BorderDark"      Color="#344B5B"/>
        <SolidColorBrush x:Key="BorderAccent"    Color="#6D97AE"/>

        <SolidColorBrush x:Key="TextHigh"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDark"        Color="#1E252B"/>
        <SolidColorBrush x:Key="TextMed"         Color="#536B7D"/>
        <SolidColorBrush x:Key="TextLow"         Color="#6F7F89"/>
        <SolidColorBrush x:Key="TextAccent"      Color="#0A70B8"/>
        <SolidColorBrush x:Key="TextFooter"      Color="#A9BAC8"/>
        <SolidColorBrush x:Key="TextCardLabel"   Color="#8FA7BA"/>

        <!-- Button colors -->
        <SolidColorBrush x:Key="BtnBlueBg"       Color="#2F4B5E"/>
        <SolidColorBrush x:Key="BtnBlueHover"    Color="#3D6178"/>
        <SolidColorBrush x:Key="BtnBluePress"    Color="#263D4D"/>

        <SolidColorBrush x:Key="BtnSlateBg"      Color="#314854"/>
        <SolidColorBrush x:Key="BtnSlateHover"   Color="#3E5A6B"/>
        <SolidColorBrush x:Key="BtnSlatePress"   Color="#263A44"/>

        <SolidColorBrush x:Key="BtnTealBg"       Color="#2F4B5E"/>
        <SolidColorBrush x:Key="BtnTealHover"    Color="#3D6178"/>
        <SolidColorBrush x:Key="BtnTealPress"    Color="#263D4D"/>

        <SolidColorBrush x:Key="BtnGreenBg"      Color="#2D9D55"/>
        <SolidColorBrush x:Key="BtnGreenHover"   Color="#49B571"/>
        <SolidColorBrush x:Key="BtnGreenPress"   Color="#1F7A3E"/>

        <SolidColorBrush x:Key="BtnRedBg"        Color="#7A3430"/>
        <SolidColorBrush x:Key="BtnRedHover"     Color="#9A4A45"/>
        <SolidColorBrush x:Key="BtnRedPress"     Color="#5C2522"/>

        <SolidColorBrush x:Key="RulesHeader"     Color="#E9EEF3"/>
        <SolidColorBrush x:Key="ProjectHeader"   Color="#E9EEF3"/>

        <!-- Compatibility aliases used by current layout -->
        <SolidColorBrush x:Key="BgSurface"       Color="#26303A"/>
        <SolidColorBrush x:Key="BgSurfaceAlt"    Color="#1F2B35"/>

        <!-- ============================================================
             SHARED BUTTON CONTROL TEMPLATE
        ============================================================ -->
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ============================================================
             ELEMENT STYLES
        ============================================================ -->

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin"     Value="0,0,0,0"/>
        </Style>

        <Style x:Key="CardLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextCardLabel}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground"              Value="{StaticResource TextDark}"/>
            <Setter Property="Background"              Value="{StaticResource BgInput}"/>
            <Setter Property="CaretBrush"              Value="{StaticResource TextAccent}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderMedium}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6,4"/>
            <Setter Property="Height"                  Value="30"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground"                Value="{StaticResource TextDark}"/>
            <Setter Property="Background"                Value="#FFFFFF"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Padding"                   Value="8,5"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCE7EF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0A70B8"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground"        Value="{StaticResource TextDark}"/>
            <Setter Property="Background"        Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderMedium}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Height"            Value="30"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding"           Value="6,0"/>
            <Setter Property="MaxDropDownHeight" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,30,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="26"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="1" Background="Transparent">
                                                <Path x:Name="Arrow"
                                                      Data="M 0 0 L 5 5 L 10 0"
                                                      Stroke="#536B7D"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Stroke" Value="#0A70B8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderMedium}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                                <Setter TargetName="MainBorder" Property="CornerRadius" Value="2,2,0,0"/>
                                <Setter TargetName="DropDownBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource BtnBlueBg}"/>
            <Setter Property="BorderBrush"     Value="#4C6B82"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="{StaticResource BtnBlueHover}"/>
            <Setter Property="Template"        Value="{StaticResource FlatButtonTemplate}"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnSlateBg}"/>
            <Setter Property="BorderBrush" Value="#4C6B82"/>
            <Setter Property="Tag"        Value="{StaticResource BtnSlateHover}"/>
        </Style>

        <Style x:Key="TealButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnTealBg}"/>
            <Setter Property="BorderBrush" Value="#4C6B82"/>
            <Setter Property="Tag"        Value="{StaticResource BtnTealHover}"/>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnGreenBg}"/>
            <Setter Property="BorderBrush" Value="#49B571"/>
            <Setter Property="Tag"        Value="{StaticResource BtnGreenHover}"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BtnRedBg}"/>
            <Setter Property="BorderBrush" Value="#9A4A45"/>
            <Setter Property="Tag"        Value="{StaticResource BtnRedHover}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground"      Value="{StaticResource TextDark}"/>
            <Setter Property="Background"      Value="{StaticResource BgContent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="Background"               Value="#F7F9FB"/>
            <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderSubtle}"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="RowBackground"            Value="{StaticResource BgRow}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRowAlt}"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="RowHeight"                Value="22"/>
            <Setter Property="ColumnHeaderHeight"       Value="26"/>
            <Setter Property="RowHeaderWidth"           Value="0"/>
            <Setter Property="SelectionMode"            Value="Extended"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgRowHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgSelection}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground"      Value="{StaticResource TextDark}"/>
            <Setter Property="Background"      Value="#E9EEF3"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Cursor"          Value="Arrow"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"           Value="{StaticResource TextDark}"/>
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness"      Value="0,0,1,0"/>
            <Setter Property="FocusVisualStyle"     Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="6,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A70B8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RulesHeaderStyle" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{StaticResource RulesHeader}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        </Style>

        <Style x:Key="ProjectHeaderStyle" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{StaticResource ProjectHeader}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        </Style>

        <Style x:Key="FastCheckStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Focusable"           Value="False"/>
            <Setter Property="Width"               Value="18"/>
            <Setter Property="Height"              Value="18"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BgApp}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="245"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgHeader}"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="0,0,0,1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="34" Height="34"
                        Background="#1F2B35"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1"
                        CornerRadius="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Image x:Name="logoImage" Stretch="Uniform" Margin="4"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,20,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="VIEW TYPE STANDARDIZER - pyMENVIC"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Load a discipline standard, analyze the project, review suggestions, then apply."
                               FontSize="12"
                               Foreground="#C3D1DD"
                               Margin="0,3,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DISCIPLINE" Style="{StaticResource CardLabelStyle}"/>
                            <ComboBox x:Name="DisciplineCombo"
                                      IsEditable="False"
                                      FontSize="15"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="LoadDisciplineButton" Grid.Column="2" Content="LOAD" Width="82" VerticalAlignment="Bottom"/>
                        <Button x:Name="ReloadTxtButton" Grid.Column="4" Content="RELOAD TXT" Width="98" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom"/>
                        <Button x:Name="SaveTxtButton" Grid.Column="6" Content="SAVE TXT" Width="90" VerticalAlignment="Bottom"/>
                        <Button x:Name="RefreshProjectButton" Grid.Column="8" Content="REFRESH" Width="82" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgMetric}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="4" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="TOTAL RULES" Style="{StaticResource CardLabelStyle}"/>
                    <TextBlock x:Name="TotalRulesText" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource BgMetric}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="4" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="PROJECT TYPES" Style="{StaticResource CardLabelStyle}"/>
                    <TextBlock x:Name="TotalTypesText" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="{StaticResource BgMetric}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="4" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="SELECTED" Style="{StaticResource CardLabelStyle}"/>
                    <TextBlock x:Name="SelectedTypesText" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="{StaticResource BgMetric}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="4" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="MATCHED" Style="{StaticResource CardLabelStyle}"/>
                    <TextBlock x:Name="MatchedTypesText" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="8" Background="{StaticResource BgMetric}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" CornerRadius="4" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="RENAMED" Style="{StaticResource CardLabelStyle}"/>
                    <TextBlock x:Name="RenamedTypesText" Text="0" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="{StaticResource BgContent}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Margin="16,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="STANDARD RULES" Style="{StaticResource SectionTitleStyle}"/>

                <DockPanel Grid.Row="2" LastChildFill="False">
                    <Button x:Name="AddRuleButton"    Content="ADD RULE"       Style="{StaticResource TealButtonStyle}" Width="100"/>
                    <Button x:Name="RemoveRuleButton" Content="REMOVE RULE"    Style="{StaticResource DangerButtonStyle}" Width="110" Margin="6,0,0,0"/>
                    <Button x:Name="MatchRulesButton" Content="ANALYZE PROJECT" Width="140" Margin="16,0,0,0"/>
                </DockPanel>

                <TextBlock x:Name="StandardRulesCountText" Grid.Row="4" Text="Showing 0 rules" FontSize="11" Foreground="{StaticResource TextLow}"/>

                <DataGrid x:Name="StandardGrid"
                          Grid.Row="6"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          ColumnHeaderStyle="{StaticResource RulesHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn x:Name="StandardFamilyColumn"
                                                Header="VIEW FAMILY"
                                                SelectedItemBinding="{Binding ViewFamilyName, UpdateSourceTrigger=PropertyChanged}"
                                                Width="210"/>
                        <DataGridTextColumn Header="OLD STANDARD NAME"
                                            Binding="{Binding OldTypeName, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NEW STANDARD NAME" Binding="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="6" Background="{StaticResource BgContent}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Margin="16,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PROJECT TYPES TO REVIEW" Style="{StaticResource SectionTitleStyle}"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VIEW FAMILY" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="ProjectFamilyFilter"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="STATUS" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="ProjectStatusFilter"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="SEARCH" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="ProjectSearchBox"/>
                    </StackPanel>

                    <TextBlock x:Name="ProjectTypesCountText" Grid.Column="5" Margin="16,0,0,0" VerticalAlignment="Bottom" FontSize="11" Foreground="{StaticResource TextLow}" Text="Showing 0 of 0 project types"/>
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <Button x:Name="CheckVisibleAddRuleButton" Content="CHECK VISIBLE — ADD RULE" Style="{StaticResource TealButtonStyle}" Width="190"/>
                    <Button x:Name="CheckVisibleUseButton" Content="CHECK VISIBLE — USE" Style="{StaticResource SecondaryButtonStyle}" Width="160" Margin="6,0,0,0"/>
                    <Button x:Name="UncheckVisibleButton" Content="UNCHECK VISIBLE" Style="{StaticResource DangerButtonStyle}" Width="140" Margin="6,0,0,0"/>
                </StackPanel>

                <DataGrid x:Name="ProjectGrid"
                          Grid.Row="6"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          ColumnHeaderStyle="{StaticResource ProjectHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="VIEW FAMILY" Binding="{Binding ViewFamilyName}" Width="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="CURRENT PROJECT TYPE" Binding="{Binding CurrentTypeName}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SUGGESTED / NEW TYPE" Binding="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBg}" CornerRadius="3" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusFg}" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ADD RULE" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding AddRule, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FastCheckStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="USE" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Include, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FastCheckStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="8"
                Background="{StaticResource BgApp}"
                Padding="3,4,3,1"
                Margin="0,2,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextFooter}"
                           Text="pyMENVIC View Type Standardizer | Workflow: LOAD standard → ANALYZE PROJECT → review suggestions → ADD RULE / USE → APPLY"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="AddCheckedToRulesButton" Content="ADD TO RULES" Style="{StaticResource TealButtonStyle}" Width="130"/>
                    <Button x:Name="ApplyButton" Content="APPLY" Style="{StaticResource GreenButtonStyle}" Width="90" Margin="8,0,0,0"/>
                    <Button x:Name="CloseButton" Content="CLOSE" Style="{StaticResource DangerButtonStyle}" Width="80" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>