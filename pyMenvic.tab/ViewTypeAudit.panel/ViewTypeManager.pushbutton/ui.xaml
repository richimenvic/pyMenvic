<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Type Standardizer"
        Height="930"
        Width="1510"
        MinHeight="800"
        MinWidth="1250"
        Background="#222933"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
        <!-- aqui Background="#252526"-->

    <Window.Resources>
        <!-- aqui <SolidColorBrush x:Key="WindowBgBrush" Color="#252526"/>-->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#222933"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="PanelBgBrush2" Color="#29323C"/>
        <SolidColorBrush x:Key="RulesHeaderBrush" Color="#46697A"/>
        <SolidColorBrush x:Key="ProjectHeaderBrush" Color="#5C4F7A"/>
        <SolidColorBrush x:Key="GridBgBrush" Color="#3B4453"/>
        <SolidColorBrush x:Key="GridAltBrush" Color="#314854"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#D7DEE3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6D97AE"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5D8194"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#416172"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#4E5A61"/>
            <Setter Property="BorderBrush" Value="#596870"/>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#4E7A56"/>
            <Setter Property="BorderBrush" Value="#6A9C73"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7A4C4C"/>
            <Setter Property="BorderBrush" Value="#8E5F5F"/>
        </Style>

        <Style x:Key="AddRulesButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#46697A"/>
            <Setter Property="BorderBrush" Value="#5C8090"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#8FA5B2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#8FA5B2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F3A44"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#8FC1E0"/>
                    <Setter Property="Foreground" Value="#10212E"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#8FC1E0"/>
                    <Setter Property="Foreground" Value="#10212E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAltBrush}"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeight" Value="20"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RulesHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{StaticResource RulesHeaderBrush}"/>
        </Style>

        <Style x:Key="ProjectHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{StaticResource ProjectHeaderBrush}"/>
        </Style>

        <Style x:Key="FastCheckStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="245"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="610"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="72" Height="72" Background="#1E1E1E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image x:Name="logoImage" Stretch="Uniform" Margin="6"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,12,0">
                    <TextBlock Text="VIEW TYPE STANDARDIZER - pyMENVIC" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Rules above. Project review below. Analyze first, then review only the family and status you want." Margin="0,6,0,0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="2" Background="{StaticResource PanelBgBrush2}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="92"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="DISCIPLINE / STANDARD" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="DisciplineCombo" IsEditable="False" FontSize="18" FontWeight="Bold" Foreground="#111111" Background="#F2F2F2"/>
                        </StackPanel>

                        <Button x:Name="LoadDisciplineButton" Grid.Column="1" Content="LOAD" Margin="0,20,8,0"/>
                        <Button x:Name="ReloadTxtButton" Grid.Column="2" Content="RELOAD" Style="{StaticResource SecondaryButtonStyle}" Margin="0,20,8,0"/>
                        <Button x:Name="SaveTxtButton" Grid.Column="3" Content="SAVE TXT" Margin="0,20,8,0"/>
                        <Button x:Name="RefreshProjectButton" Grid.Column="4" Content="REFRESH" Style="{StaticResource SecondaryButtonStyle}" Margin="0,20,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,0"><StackPanel><TextBlock Text="TOTAL RULES" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/><TextBlock x:Name="TotalRulesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,0"><StackPanel><TextBlock Text="TOTAL TYPES" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/><TextBlock x:Name="TotalTypesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="2" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,0"><StackPanel><TextBlock Text="SELECTED" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/><TextBlock x:Name="SelectedTypesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="3" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,10,0"><StackPanel><TextBlock Text="MATCHED" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/><TextBlock x:Name="MatchedTypesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="4" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10"><StackPanel><TextBlock Text="RENAMED" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/><TextBlock x:Name="RenamedTypesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
        </Grid>

        <GroupBox Grid.Row="2" Header="STANDARD RULES">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <Button x:Name="AddRuleButton" Content="ADD RULE" Style="{StaticResource AddRulesButtonStyle}"/>
                    <Button x:Name="RemoveRuleButton" Content="REMOVE RULE" Style="{StaticResource DangerButtonStyle}"/>
                    <Button x:Name="MatchRulesButton" Content="ANALYZE PROJECT" Margin="16,0,0,0"/>
                </DockPanel>

                <TextBlock x:Name="StandardRulesCountText" Grid.Row="1" Margin="2,8,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="Showing 0 rules"/>

                <DataGrid x:Name="StandardGrid" Grid.Row="3" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended" SelectionUnit="FullRow" ColumnHeaderStyle="{StaticResource RulesHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn x:Name="StandardFamilyColumn"
                                                Header="VIEW FAMILY"
                                                SelectedItemBinding="{Binding ViewFamilyName, UpdateSourceTrigger=PropertyChanged}"
                                                Width="210"/>

                        <DataGridTextColumn Header="OLD STANDARD NAME" Binding="{Binding OldTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="NEW STANDARD NAME" Binding="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
<!-- 
                <DataGrid x:Name="StandardGrid" Grid.Row="3" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended" SelectionUnit="FullRow" ColumnHeaderStyle="{StaticResource RulesHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn Header="VIEW FAMILY" Binding="{Binding OldTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="OLD STANDARD NAME" Binding="{Binding OldTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NEW STANDARD NAME" Binding="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                                            
                    </DataGrid.Columns>
                </DataGrid> -->
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="PROJECT TYPES TO REVIEW">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="FILTER VIEW FAMILY" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ProjectFamilyFilter" Foreground="#111111" Background="#F2F2F2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="SHOW STATUS" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ProjectStatusFilter" Foreground="#111111" Background="#F2F2F2"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="SEARCH" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ProjectSearchBox" Height="32" Padding="8,4"/>
                    </StackPanel>

                    <TextBlock x:Name="ProjectTypesCountText" Grid.Row="0" Grid.Column="3" Margin="8,24,0,0" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Top" Text="Showing 0 of 0 project types"/>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="CheckVisibleAddRuleButton" Content="CHECK VISIBLE ADD RULE" Style="{StaticResource AddRulesButtonStyle}"/>
                        <Button x:Name="CheckVisibleUseButton" Content="CHECK VISIBLE USE" Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="UncheckVisibleButton" Content="UNCHECK VISIBLE" Style="{StaticResource DangerButtonStyle}"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="ProjectGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended" SelectionUnit="FullRow" ColumnHeaderStyle="{StaticResource ProjectHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="VIEW FAMILY" Binding="{Binding ViewFamilyName}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="CURRENT PROJECT TYPE" Binding="{Binding CurrentTypeName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="SUGGESTED / NEW TYPE" Binding="{Binding NewTypeName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTemplateColumn Header="STATUS" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBg}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusFg}" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ADD RULE" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding AddRule, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FastCheckStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="USE" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Include, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FastCheckStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <Border Grid.Row="6" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" Text="Workflow: LOAD standard → ANALYZE PROJECT → filter → edit suggestions → check ADD RULE and/or USE → APPLY."/>
                <Button x:Name="AddCheckedToRulesButton" Grid.Column="1" Content="ADD TO RULES" Style="{StaticResource AddRulesButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="ApplyButton" Grid.Column="2" Content="APPLY" Style="{StaticResource GreenButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="CloseButton" Grid.Column="3" Content="CLOSE" Style="{StaticResource DangerButtonStyle}" Margin="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
