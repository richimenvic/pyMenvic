<!-- AddTableWindow.xaml -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Table"
    Width="620"
    Height="420"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#1E1F22">

    <Border Margin="16"
            Padding="18"
            Background="#25262A"
            BorderBrush="#3A3C42"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="ADD TABLE"
                           Foreground="#F2F2F2"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Select an Excel file and define the view properties."
                           Foreground="#A8ADB7"
                           FontSize="12"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Form -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <!-- File -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Excel File"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="FilePathTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Height="30"
                         Padding="8,4"
                         Foreground="#F2F2F2"
                         Background="#1B1C20"
                         BorderBrush="#464951"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="BrowseButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="Browse"
                        Height="30"
                        Margin="10,0,0,0"/>

                <!-- Worksheet -->
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Worksheet"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="WorksheetComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Height="30"
                          Background="#1B1C20"
                          Foreground="#F2F2F2"
                          BorderBrush="#464951"
                          VerticalContentAlignment="Center"/>

                <!-- Region -->
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="Region"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="RegionComboBox"
                          Grid.Row="4"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Height="30"
                          Background="#1B1C20"
                          Foreground="#F2F2F2"
                          BorderBrush="#464951"
                          VerticalContentAlignment="Center"/>

                <!-- View Type -->
                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Text="View Type"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="ViewTypeComboBox"
                          Grid.Row="6"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Height="30"
                          Background="#1B1C20"
                          Foreground="#F2F2F2"
                          BorderBrush="#464951"
                          VerticalContentAlignment="Center"/>

                <!-- View Scale -->
                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Text="View Scale"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="ViewScaleComboBox"
                          Grid.Row="8"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Height="30"
                          Background="#1B1C20"
                          Foreground="#F2F2F2"
                          BorderBrush="#464951"
                          VerticalContentAlignment="Center"/>

                <!-- Copies -->
                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           Text="Number of Copies"
                           Foreground="#D6D8DD"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="CopiesTextBox"
                         Grid.Row="10"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Height="30"
                         Padding="8,4"
                         Text="1"
                         Foreground="#F2F2F2"
                         Background="#1B1C20"
                         BorderBrush="#464951"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <!-- Footer -->
            <DockPanel Grid.Row="4">
                <TextBlock x:Name="StatusTextBlock"
                           Text=""
                           Foreground="#A8ADB7"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Width="90"
                            Height="32"
                            Margin="0,0,8,0"/>

                    <Button x:Name="OkButton"
                            Content="OK"
                            Width="90"
                            Height="32"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>