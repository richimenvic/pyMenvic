<!-- AddTableWindow.xaml - multi-file Table Importer intake -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Tables"
    Width="850"
    Height="548"
    MinWidth="740"
    MinHeight="500"
    WindowStartupLocation="CenterOwner"
    Background="#F2F2F2">

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#2F2F2F"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8A8A8A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>
        <SolidColorBrush x:Key="LineBrush" Color="#C8C8C8"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#D9AF52"/>
        <SolidColorBrush x:Key="GoldHoverBrush" Color="#C99E42"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#9CCC65"/>
        <SolidColorBrush x:Key="GreenHoverBrush" Color="#8BC34A"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#EFEFEF"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#BDBDBD"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{StaticResource ButtonPressedBrush}"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GoldButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderBrush" Value="#B99643"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource GoldHoverBrush}"/></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#B88F38"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#79A94F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource GreenHoverBrush}"/></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#7EAD3E"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="62"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ADD TABLES" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Stage one row per selected Excel file, with shared default table properties." Margin="0,3,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
            <TextBlock x:Name="VersionTextBlock" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="3" Margin="0,4,0,4">
                <Image x:Name="LogoImage" Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="88"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="164"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Excel Files" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="FilePathTextBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True"/>
                <Button x:Name="BrowseButton" Grid.Row="0" Grid.Column="2" Content="Browse" Margin="8,0,0,0" Style="{StaticResource GoldButton}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Selected Files" VerticalAlignment="Top" Margin="0,8,0,0" FontWeight="SemiBold"/>
                <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4,0,6">
                    <ListBox x:Name="FilesListBox"/>
                    <TextBlock x:Name="NoFilesTextBlock" Text="No files selected." Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Worksheet" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="WorksheetComboBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Region" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="RegionComboBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Type" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="ImportTypeComboBox" Grid.Row="4" Grid.Column="1"/>
                <CheckBox x:Name="AutoSyncCheckBox" Grid.Row="4" Grid.Column="2" Content="Auto Sync" VerticalAlignment="Center" Margin="12,0,0,0"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="View Type" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="ViewTypeComboBox" Grid.Row="5" Grid.Column="1"/>
                <Grid Grid.Row="5" Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Scale" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ViewScaleComboBox" Grid.Column="1" MinWidth="76"/>
                </Grid>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Output" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Grid Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="DPI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="DpiComboBox" Grid.Column="1"/>
                    <CheckBox x:Name="BlackAndWhiteCheckBox" Grid.Column="2" Content="Black and White" VerticalAlignment="Center" Margin="18,0,0,0"/>
                </Grid>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Rows per File" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="CopiesTextBox" Grid.Row="7" Grid.Column="1" Width="92" HorizontalAlignment="Left"/>

                <TextBlock x:Name="StatusTextBlock" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Text="Ready." Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="CancelButton" Content="Cancel" Width="108"/>
                <Button x:Name="OkButton" Content="Add" Width="118" Margin="4,0,0,0" Style="{StaticResource GreenButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

