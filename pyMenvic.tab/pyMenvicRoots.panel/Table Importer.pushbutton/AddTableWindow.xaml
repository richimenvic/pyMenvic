<!-- AddTableWindow.xaml - SheetLink style light UI -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Table"
    Width="760"
    Height="500"
    MinWidth="680"
    MinHeight="460"
    WindowStartupLocation="CenterOwner"
    Background="#EDEDED">

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#4D4D4D"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E6E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#E6B85B"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#9DDD70"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,3"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#9B9B9B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFEFEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D2D2D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderBrush" Value="#7CAE55"/>
            <Setter Property="Foreground" Value="#38512A"/>
        </Style>

        <Style x:Key="GoldButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#B8944B"/>
            <Setter Property="Foreground" Value="#4C4C4C"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#A5A5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#333333"/>
            <Setter Property="SelectionBrush" Value="#B7D7F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#A5A5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="62"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="ADD TABLE" FontSize="22" FontWeight="SemiBold" Foreground="#3E3E3E"/>
                <TextBlock Text="Select an Excel file and define the view properties." Margin="0,4,0,0" Foreground="#6A6A6A"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="4" Margin="0,6,0,6">
                <TextBlock Text="M" FontSize="28" FontWeight="Bold" Foreground="#D8A64F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#A5A5A5" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Excel File" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="FilePathTextBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True"/>
                <Button x:Name="BrowseButton" Grid.Row="0" Grid.Column="2" Content="Browse" Margin="8,0,0,0" Style="{StaticResource GoldButton}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Worksheet" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="WorksheetComboBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Region" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="RegionComboBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="View Type" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="ViewTypeComboBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="View Scale" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="ViewScaleComboBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Number of Copies" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="CopiesTextBox" Grid.Row="5" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>

                <TextBlock x:Name="StatusTextBlock" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="Ready."
                           Foreground="#6E6E6E"
                           VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="CancelButton" Content="Cancel" Width="110"/>
                <Button x:Name="OkButton" Content="OK" Width="110" Margin="4,0,0,0" Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
