<!-- TableImporter.xaml -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Menvic Table Importer"
    Width="1180"
    Height="680"
    MinWidth="980"
    MinHeight="560"
    WindowStartupLocation="CenterScreen"
    Background="#1E1F22">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Background" Value="#1B1C20"/>
            <Setter Property="BorderBrush" Value="#464951"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#1B1C20"/>
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#464951"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="#25262A"
            BorderBrush="#3A3C42"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="MENVIC TABLE IMPORTER"
                               Foreground="#F2F2F2"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Manage linked Excel tables and create Revit views."
                               Foreground="#A8ADB7"
                               FontSize="12"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <TextBlock x:Name="VersionTextBlock"
                           Grid.Column="1"
                           Text="MVP 0.1"
                           Foreground="#A8ADB7"
                           FontSize="12"
                           VerticalAlignment="Top"/>
            </Grid>

            <!-- Toolbar -->
            <Border Grid.Row="2"
                    Padding="10"
                    Background="#202126"
                    BorderBrush="#34363D"
                    BorderThickness="1"
                    CornerRadius="8">

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal">

                        <Button x:Name="AddTablesButton"
                                Content="Add Tables"/>

                        <Button x:Name="BatchActionsButton"
                                Content="Batch Actions"/>

                        <Button x:Name="RefreshButton"
                                Content="Refresh"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">

                        <TextBlock Text="Search"
                                   Foreground="#A8ADB7"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="SearchTextBox"
                                 Width="240"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main Grid -->
            <Border Grid.Row="4"
                    Background="#1B1C20"
                    BorderBrush="#34363D"
                    BorderThickness="1"
                    CornerRadius="8">

                <DataGrid x:Name="TablesDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          Background="#1B1C20"
                          Foreground="#F2F2F2"
                          BorderThickness="0"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow">

                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="✓"
                                                Binding="{Binding Selected}"
                                                Width="42"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="110"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="View Name"
                                            Binding="{Binding ViewName}"
                                            Width="190"/>

                        <DataGridCheckBoxColumn Header="Auto Sync"
                                                Binding="{Binding AutoSync}"
                                                Width="90"/>

                        <DataGridTextColumn Header="Last Modified"
                                            Binding="{Binding LastModified}"
                                            Width="140"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Worksheet"
                                            Binding="{Binding Worksheet}"
                                            Width="150"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Region"
                                            Binding="{Binding Region}"
                                            Width="110"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="View Type"
                                            Binding="{Binding ViewType}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Scale"
                                            Binding="{Binding ViewScale}"
                                            Width="70"/>

                        <DataGridTextColumn Header="File Path"
                                            Binding="{Binding FilePath}"
                                            Width="*"
                                            IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterStatusTextBlock"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="#A8ADB7"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button x:Name="CloseButton"
                            Content="Close"
                            Width="90"/>

                    <Button x:Name="ApplyButton"
                            Content="Apply"
                            Width="100"
                            Margin="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>