<!-- TableImporter.xaml - SheetLink style light UI -->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    Title="Table Importer - pyMENVIC"
    Width="1250"
    Height="720"
    MinWidth="1050"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#EDEDED">

    <Window.Resources>
        <!-- Palette: closer to SheetLink / TableGen light UI -->
        <SolidColorBrush x:Key="BgBrush" Color="#EDEDED"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#4D4D4D"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E6E"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#E6B85B"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#F0C973"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#9DDD70"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#6F87A8"/>
        <SolidColorBrush x:Key="SelectBrush" Color="#DCEBFA"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#9B9B9B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFEFEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D2D2D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9A9A9A"/>
                                <Setter TargetName="bd" Property="Background" Value="#ECECEC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderBrush" Value="#7CAE55"/>
            <Setter Property="Foreground" Value="#38512A"/>
        </Style>

        <Style x:Key="GoldButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#B8944B"/>
            <Setter Property="Foreground" Value="#4C4C4C"/>
        </Style>

        <Style x:Key="AddTablesButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="136"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#9B9B9B"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#A5A5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#333333"/>
            <Setter Property="SelectionBrush" Value="#B7D7F2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="Foreground" Value="#5F5F5F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#9D9D9D"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Height" Value="29"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectBrush}"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="Background" Value="#E8F1FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GridTextBlock" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="MutedGridTextBlock" TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        </Style>

        <Style x:Key="DataGridComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCEBFA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#BFD8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7E9CB8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DataGridComboBoxItemStyle}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#A5A5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#E7E7E7"/>
            <Setter Property="BorderBrush" Value="#9C9C9C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F2C86C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- Header similar to pyMENVIC SheetLink -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="MENVIC TABLE IMPORTER"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#3E3E3E"/>
                <TextBlock Text="Manage linked Excel tables and create Revit views."
                           Margin="1,4,0,0"
                           Foreground="#6A6A6A"/>
            </StackPanel>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="4" Margin="0,0,8,0">
                    <Grid>
                        <TextBlock Text="M" FontSize="28" FontWeight="Bold" Foreground="#D8A64F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1">
                    <Border Background="#FFFFFF" BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="4" Height="32" Padding="8,0">
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <Run Text="Status:" FontWeight="SemiBold"/>
                            <Run Text="  Tables loaded | Views: 0 | MVP 0.1"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="4" Height="18" Margin="0,4,0,0" Padding="6,2">
                        <Grid>
                            <TextBlock Text="Ready   100%" FontSize="10" VerticalAlignment="Center" Foreground="#666666"/>
                            <Border Height="5" Background="{StaticResource GreenBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="70,0,0,1"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,6,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="AddTablesButton" Grid.Column="0" Style="{StaticResource AddTablesButtonStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource AccentBrush}" BorderBrush="#B8944B" BorderThickness="0,0,1,0">
                        <TextBlock Text="+" FontSize="28" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="Add Tables" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                </Grid>
            </Button>

            <Button x:Name="BatchActionsButton" Grid.Column="1" Content="Batch Actions   ▾" Width="150">
                <Button.ContextMenu>
                    <ContextMenu x:Name="BatchActionsContextMenu" Width="220">
                        <MenuItem x:Name="BatchUpdateViewsMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" Width="28" Foreground="#2478C8" FontSize="17"/>
                                    <TextBlock Text="Update Views"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem x:Name="BatchDuplicateViewsMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▣" Width="28" Foreground="#666666" FontSize="16"/>
                                    <TextBlock Text="Duplicate Views"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem x:Name="BatchAbsolutePathMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↔" Width="28" Foreground="#76B82A" FontSize="17"/>
                                    <TextBlock Text="Absolute Path"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem x:Name="BatchRelativePathMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⇄" Width="28" Foreground="#76B82A" FontSize="17"/>
                                    <TextBlock Text="Relative Path"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem x:Name="BatchOpenFilesMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▤" Width="28" Foreground="#777777" FontSize="16"/>
                                    <TextBlock Text="Open Files"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem x:Name="BatchOpenFoldersMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▰" Width="28" Foreground="#E6B85B" FontSize="16"/>
                                    <TextBlock Text="Open Folders"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator/>
                        <MenuItem x:Name="BatchDeleteViewsMenuItem">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▥" Width="28" Foreground="#777777" FontSize="16"/>
                                    <TextBlock Text="Delete Views"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <Button x:Name="RefreshButton" Grid.Column="2" Style="{StaticResource GoldButton}" Width="40" Padding="0" Content="↻" FontSize="22"/>

            <Grid Grid.Column="4" VerticalAlignment="Center">
                <TextBox x:Name="SearchTextBox" Height="36" Padding="10,4,36,4"/>
                <TextBlock Text="Search" IsHitTestVisible="False" Foreground="#777777" Margin="12,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <TextBlock Text="⌕" IsHitTestVisible="False" FontSize="24" Foreground="#7A8798" Margin="0,0,10,1" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <Border Grid.Column="6" Height="36" Background="#FFFFFF" BorderBrush="#A5A5A5" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center" Padding="10,0">
                <TextBlock Text="Completed 0%" Foreground="#777777" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Main grid -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#9D9D9D" BorderThickness="1">
            <DataGrid x:Name="TablesDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#D3D3D3"
                      VerticalGridLinesBrush="#D3D3D3"
                      Background="#FFFFFF"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓"
                                            Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="42"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="105"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="View Name"
                                        Binding="{Binding ViewName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="210">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridCheckBoxColumn Header="Auto Sync"
                                            Binding="{Binding AutoSync, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="85"/>

                    <DataGridTextColumn Header="Last Modified"
                                        Binding="{Binding LastModified}"
                                        Width="135"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedGridTextBlock}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="WorkSheet"
                                        Binding="{Binding Worksheet}"
                                        Width="135"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextBlock}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Region" Width="250" MinWidth="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Region}"
                                           Style="{StaticResource MutedGridTextBlock}"
                                           ToolTip="{Binding Region}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding RegionOptions}"
                                          SelectedItem="{Binding Region, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False"
                                          Style="{StaticResource DataGridComboBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="View Type" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ViewType}" Style="{StaticResource GridTextBlock}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding ViewType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False"
                                          Style="{StaticResource DataGridComboBoxStyle}">
                                    <System:String>Drafting View</System:String>
                                    <System:String>Legend View</System:String>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Scale" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ViewScale}" Style="{StaticResource GridTextBlock}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding ViewScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False"
                                          Style="{StaticResource DataGridComboBoxStyle}">
                                    <System:String>1</System:String>
                                    <System:String>2</System:String>
                                    <System:String>5</System:String>
                                    <System:String>10</System:String>
                                    <System:String>20</System:String>
                                    <System:String>25</System:String>
                                    <System:String>50</System:String>
                                    <System:String>75</System:String>
                                    <System:String>100</System:String>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="File Path"
                                        Binding="{Binding FilePath}"
                                        Width="*"
                                        MinWidth="190"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedGridTextBlock}">
                                <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FooterStatusTextBlock"
                       Grid.Column="0"
                       Text="Total 0 | Legends 0 | Schedules 0 | Drafting 0 | Staging 0"
                       Foreground="#5E5E5E"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="CloseButton" Content="Close" Width="110" Height="36"/>
                <Button x:Name="ApplyButton" Content="Apply" Width="120" Height="36" Margin="4,0,0,0" Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
