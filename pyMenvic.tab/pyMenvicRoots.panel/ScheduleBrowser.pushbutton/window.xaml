<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Schedule Browser"
    Height="720"
    Width="1180"
    MinHeight="620"
    MinWidth="980"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#252526"
    Foreground="White">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#252526"/>
        <SolidColorBrush x:Key="BgPanel" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BgPanel2" Color="#314854"/>
        <SolidColorBrush x:Key="BgGrid" Color="#3B4453"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3F3F46"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#D7DEE3"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#6D97AE"/>
        <SolidColorBrush x:Key="AccentBlueHover" Color="#5D8194"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#5B8AA3"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3E5A6B"/>
        <SolidColorBrush x:Key="GreenBtn" Color="#74B95E"/>
        <SolidColorBrush x:Key="GreenBtnHover" Color="#689F54"/>
        <SolidColorBrush x:Key="DisabledBtn" Color="#555555"/>

        <SolidColorBrush x:Key="EditableYesBrush" Color="#365B3A"/>
        <SolidColorBrush x:Key="EditableNoBrush" Color="#5B3A3A"/>
        <SolidColorBrush x:Key="EditableUnknownBrush" Color="#4D4D4D"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1F1F22"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledBtn}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource GreenBtn}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GreenBtnHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledBtn}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPanel}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgGrid}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgPanel2}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ParameterRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editable}" Value="Yes">
                    <Setter Property="Background" Value="{StaticResource EditableYesBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="No">
                    <Setter Property="Background" Value="{StaticResource EditableNoBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="Unknown">
                    <Setter Property="Background" Value="{StaticResource EditableUnknownBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Schedule Browser"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Preview schedule fields and export selected schedules to Excel"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <TextBlock x:Name="lblStatus"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"
                           Text="Schedules: 0 | Checked: 0 | Fields: 0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Schedules"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <DockPanel Grid.Row="2" LastChildFill="True">
                        <CheckBox x:Name="chkSelectAll"
                                  Content="Select all"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"/>
                        <TextBox x:Name="txtSearchSchedules"
                                 Height="32"
                                 VerticalAlignment="Center"
                                 ToolTip="Search schedules"/>
                    </DockPanel>

                    <ListBox x:Name="lstSchedules"
                             Grid.Row="4"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsChecked}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Parameters"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtSearchParameters"
                             Grid.Row="2"
                             Height="32"
                             ToolTip="Search parameters"/>

                    <DataGrid x:Name="dgParameters"
                              Grid.Row="4"
                              AlternationCount="2"
                              RowStyle="{StaticResource ParameterRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name}"
                                                Width="*"
                                                MinWidth="260"
                                                ElementStyle="{StaticResource DataGridTextStyle}"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="190"
                                                MinWidth="170"
                                                ElementStyle="{StaticResource DataGridTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                Padding="12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="btnRefresh"
                            Content="Refresh"
                            Width="100"
                            Margin="0,0,6,0"/>
                    <Button x:Name="btnExport"
                            Content="Export"
                            Width="120"
                            Style="{StaticResource ExportButtonStyle}"/>
                    <Button x:Name="btnClose"
                            Content="Close"
                            Width="100"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>