<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SheetLink - pyMENVIC"
    Height="760"
    Width="1380"
    MinHeight="720"
    MinWidth="1180"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#ECECEC"
    Foreground="#2E2E2E"
    FontFamily="Segoe UI"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="Auto"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#ECECEC"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FCFCFC"/>
        <SolidColorBrush x:Key="BorderBrushMain" Color="#A9A9A9"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="TabBg" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="TabActiveBg" Color="#F8F8F8"/>
        <SolidColorBrush x:Key="AccentGold" Color="#F3C86A"/>
        <SolidColorBrush x:Key="AccentGoldDark" Color="#D6A84F"/>
        <SolidColorBrush x:Key="ProgressBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#2E2E2E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#595959"/>
        <SolidColorBrush x:Key="TextMuted" Color="#888888"/>
        <SolidColorBrush x:Key="ActionBg" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ActionHover" Color="#EBEBEB"/>
        <SolidColorBrush x:Key="WarningBg" Color="#FFEAA8"/>
        <SolidColorBrush x:Key="ImportBg" Color="#A6DB73"/>
        <SolidColorBrush x:Key="ImportHover" Color="#97CD65"/>
        <SolidColorBrush x:Key="ExportBg" Color="#9FDC71"/>
        <SolidColorBrush x:Key="ExportHover" Color="#8ECE63"/>
        <SolidColorBrush x:Key="SelectionBg" Color="#BFE4F8"/>
        <SolidColorBrush x:Key="InstanceBg" Color="#EEFAD7"/>
        <SolidColorBrush x:Key="TypeBg" Color="#F9F1C9"/>
        <SolidColorBrush x:Key="ReadOnlyBg" Color="#F7D9D3"/>
        <SolidColorBrush x:Key="UnknownBg" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#D6D6D6"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource ActionBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActionHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                    <Setter Property="Background" Value="#EAEAEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource TabBg}"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Margin" Value="0,0,1,0"/>
            <Setter Property="MinWidth" Value="102"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="ImportButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ImportBg}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ImportHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ExportBg}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExportHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBg}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF7FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ParameterRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editable}" Value="Yes">
                    <Setter Property="Background" Value="{StaticResource InstanceBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Origin}" Value="Type">
                    <Setter Property="Background" Value="{StaticResource TypeBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="No">
                    <Setter Property="Background" Value="{StaticResource ReadOnlyBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="Unknown">
                    <Setter Property="Background" Value="{StaticResource UnknownBg}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ParameterListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editable}" Value="Yes">
                    <Setter Property="Background" Value="{StaticResource InstanceBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Origin}" Value="Type">
                    <Setter Property="Background" Value="{StaticResource TypeBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="No">
                    <Setter Property="Background" Value="{StaticResource ReadOnlyBg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Editable}" Value="Unknown">
                    <Setter Property="Background" Value="{StaticResource UnknownBg}"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBg}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF7FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ParameterSquareStyle" TargetType="Rectangle">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SymbolKind}" Value="Instance">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ParameterTriangleStyle" TargetType="Polygon">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SymbolKind}" Value="Type">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ParameterCircleStyle" TargetType="Ellipse">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SymbolKind}" Value="ReadOnly">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchIconPathStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#8A9BB2"/>
            <Setter Property="StrokeThickness" Value="1.8"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource BorderBrushMain}"
            BorderThickness="1"
            Margin="2">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeaderBg}"
                    BorderBrush="{StaticResource BorderBrushMain}"
                    BorderThickness="1"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="imgLogo"
                            Width="64"
                            Height="36"
                            Stretch="Uniform"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"/>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="lblHeaderTitle"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Text="SheetLink 1.5.0.0"/>
                        <TextBlock x:Name="lblHeaderSubtitle"
                                   Margin="0,2,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="10"
                                   Text="pyMENVIC Excel-first workflow"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                            Width="410"
                                HorizontalAlignment="Right">
                        <Border Background="{StaticResource PanelBg}"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Status:"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="lblStatus"
                                           Margin="6,0,0,0"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap"
                                           Text="Schedules: 0 | Fields: 0"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,5,0,0"
                                Background="{StaticResource ProgressBg}"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,2">
                            <StackPanel>
                                <TextBlock x:Name="lblHeaderProgress"
                                           HorizontalAlignment="Left"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="Completed   0%"/>
                                <ProgressBar x:Name="prgHeaderProgress"
                                             Margin="0,4,0,0"
                                             Height="7"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Foreground="{StaticResource ExportBg}"
                                             Background="#E9E9E9"
                                             BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnNavModelCategories"
                            Content="Model Categories"
                            Tag="Model Categories"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="btnNavAnnotationCategories"
                            Content="Annotation Categories"
                            Tag="Annotation Categories"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="btnNavElements"
                            Content="Elements"
                            Tag="Elements"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="btnNavSchedules"
                            Content="Schedules"
                            Tag="Schedules"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="btnNavSpatial"
                            Content="Spatial"
                            Tag="Spatial"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="btnNavPreviewEdit"
                            Content="Preview/Edit"
                            Tag="Preview/Edit"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="lblIntroText"
                           Text="Select one schedule, review its parameters, then export or import Excel changes."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="10"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnRefresh"
                            Width="98"
                            Height="26"
                            Margin="0,0,8,0">
                        <TextBlock Text="Refresh"
                                   FontFamily="Arial"
                                   FontSize="12"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType"
                                   SnapsToDevicePixels="True"/>
                    </Button>
                    <Button x:Name="btnClose"
                            Width="98"
                            Height="26"
                            Margin="0,0,0,0">
                        <TextBlock Text="Close"
                                   FontFamily="Arial"
                                   FontSize="12"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType"
                                   SnapsToDevicePixels="True"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="6">
                <Border x:Name="panelSchedules"
                        Background="{StaticResource WindowBg}"
                        Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.72*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBg}"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>

                                <Border Background="#F5F5F5"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="0,0,0,1"
                                        Grid.Row="0">
                                    <TextBlock Text="Select Schedule"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtSearchSchedules"
                                                 Height="30"
                                                 VerticalAlignment="Center"/>
                                         <Viewbox Grid.Column="1"
                                                  Width="18"
                                                  Height="18"
                                                  Margin="10,0,0,0"
                                                  Stretch="Uniform">
                                             <Canvas Width="18" Height="18">
                                                 <Ellipse Canvas.Left="2.5"
                                                          Canvas.Top="2.5"
                                                          Width="9"
                                                          Height="9"
                                                          Stroke="#8A9BB2"
                                                          StrokeThickness="1.8"/>
                                                 <Line X1="10.5"
                                                       Y1="10.5"
                                                       X2="15"
                                                       Y2="15"
                                                       Stroke="#8A9BB2"
                                                       StrokeThickness="1.8"
                                                       StrokeStartLineCap="Round"
                                                       StrokeEndLineCap="Round"/>
                                             </Canvas>
                                         </Viewbox>
                                    </Grid>
                                </Border>

                                <ListBox x:Name="lstSchedules"
                                         Grid.Row="2"
                                         BorderThickness="0"
                                         SelectionMode="Single">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True">
                                                <CheckBox Margin="0,0,8,0"
                                                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"/>
                                                <TextBlock Text="{Binding Name}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid Grid.Row="3"
                                      Margin="8,6,8,6">
                                    <TextBlock Text="Selection drives the parameter list and Excel workflow."
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="12"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource PanelBg}"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="52"/>
                                </Grid.RowDefinitions>

                                <Border Background="#F5F5F5"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="0,0,0,1"
                                        Grid.Row="0">
                                    <TextBlock Text="Parameters"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,0">
                                    <DockPanel>
                                        <TextBlock Text="Instance, Type, Read-only"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="18"
                                                   Text="⌄"/>
                                    </DockPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtSearchParameters"
                                                 Height="30"
                                                 VerticalAlignment="Center"/>
                                         <Viewbox Grid.Column="1"
                                                  Width="18"
                                                  Height="18"
                                                  Margin="10,0,0,0"
                                                  Stretch="Uniform">
                                             <Canvas Width="18" Height="18">
                                                 <Ellipse Canvas.Left="2.5"
                                                          Canvas.Top="2.5"
                                                          Width="9"
                                                          Height="9"
                                                          Stroke="#8A9BB2"
                                                          StrokeThickness="1.8"/>
                                                 <Line X1="10.5"
                                                       Y1="10.5"
                                                       X2="15"
                                                       Y2="15"
                                                       Stroke="#8A9BB2"
                                                       StrokeThickness="1.8"
                                                       StrokeStartLineCap="Round"
                                                       StrokeEndLineCap="Round"/>
                                             </Canvas>
                                         </Viewbox>
                                    </Grid>
                                </Border>

                                <DataGrid x:Name="dgParameters"
                                          Grid.Row="3"
                                          BorderThickness="0"
                                          RowStyle="{StaticResource ParameterRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Parameter"
                                                                Width="*"
                                                                MinWidth="280">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="10,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center">
                                                            <Rectangle Width="13"
                                                                       Height="13"
                                                                       Fill="#8E8E8E"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Style="{StaticResource ParameterSquareStyle}"/>
                                                            <Polygon Width="14"
                                                                     Height="14"
                                                                     Fill="#8E8E8E"
                                                                     Stretch="Fill"
                                                                     Points="7,0 14,14 0,14"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Style="{StaticResource ParameterTriangleStyle}"/>
                                                            <Ellipse Width="15"
                                                                     Height="15"
                                                                     Fill="#8E8E8E"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Style="{StaticResource ParameterCircleStyle}"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            Width="220"
                                                            MinWidth="180"
                                                            ElementStyle="{StaticResource DataGridTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="4"
                                      Margin="6,8,6,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource InstanceBg}"
                                            BorderBrush="{StaticResource BorderBrushMain}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,0,4,0"
                                            Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="13"
                                                       Height="13"
                                                       Fill="#B1B1B1"/>
                                            <TextBlock Margin="8,0,0,0"
                                                       Text="Instance"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="{StaticResource TypeBg}"
                                            BorderBrush="{StaticResource BorderBrushMain}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="2,0,2,0"
                                            Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Polygon Width="15"
                                                     Height="15"
                                                     Fill="#B1B1B1"
                                                     Stretch="Fill"
                                                     Points="7.5,0 15,15 0,15"/>
                                            <TextBlock Margin="8,0,0,0"
