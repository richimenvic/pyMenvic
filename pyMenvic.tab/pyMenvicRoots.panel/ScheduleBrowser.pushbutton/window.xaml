                                   x:Name="lblSpatialInfo"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   Text="Spatial workflows for rooms and spaces can be staged here with their own import/export rules."/>

                        <Border Grid.Row="4"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1"
                                Padding="18">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           FontSize="14"
                                           Text="Room and space path"/>
                                <TextBlock Margin="0,10,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="This section is now reachable and ready to become the place for room and space parameter exchange."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="panelPreviewEdit"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource BorderBrushMain}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Preview/Edit"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="lblPreviewSchedule"
                                           FontWeight="SemiBold"
                                           Text="No selection"/>
                                <TextBlock Text="  |  "
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="lblPreviewParameterCount"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="Parameters ready: 0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="btnGoSchedules"
                                        Content="Back to Schedules"
                                        Width="130"
                                        Height="30"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="btnPreviewImport"
                                        Content="Update Model"
                                        Width="125"
                                        Height="30"
                                        Style="{StaticResource ImportButtonStyle}"
                                        Margin="0,0,6,0"/>
                                <Button x:Name="btnPreviewExport"
                                        Content="Export"
                                        Width="100"
                                        Height="30"
                                        Style="{StaticResource ExportButtonStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushMain}"
                                BorderThickness="1">
                            <DataGrid x:Name="dgPreviewEdit"
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      SelectionUnit="Cell"
                                      BorderThickness="0"/>
                        </Border>

                        <TextBlock Grid.Row="4"
                                   x:Name="lblPreviewWorkflow"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="Preview the selected Revit data in a spreadsheet-like grid before exporting or importing Excel changes."/>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           x:Name="lblFooterSummary"
                           Text="Total number of selected schedules and detected parameters"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnResetValues"
                            Content="Reset Values"
                            Width="138"
                            Height="38"
                            IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="btnImportExcel"
                            Content="Import ▾"
                            Width="138"
                            Height="38"
                            Style="{StaticResource ImportButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button x:Name="btnExport"
                            Content="Export"
                            Width="138"
                            Height="38"
                            Style="{StaticResource ExportButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
