<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workset Mapping Manager"
        Height="920"
        Width="1560"
        MinHeight="760"
        MinWidth="1280"
        Background="#1C2128"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <SolidColorBrush x:Key="BgApp" Color="#1C2128"/>
        <SolidColorBrush x:Key="BgSurface" Color="#252B35"/>
        <SolidColorBrush x:Key="BgSurfaceAlt" Color="#2C3340"/>
        <SolidColorBrush x:Key="BgInput" Color="#161B22"/>
        <SolidColorBrush x:Key="BgRow" Color="#252B35"/>
        <SolidColorBrush x:Key="BgRowAlt" Color="#2A3040"/>
        <SolidColorBrush x:Key="BgRowHover" Color="#2F3A4E"/>
        <SolidColorBrush x:Key="BgSelection" Color="#1F4068"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#1E2730"/>

        <SolidColorBrush x:Key="BgPending" Color="#1E3528"/>
        <SolidColorBrush x:Key="BgReview" Color="#3A2418"/>

        <SolidColorBrush x:Key="BorderSubtle" Color="#30404F"/>
        <SolidColorBrush x:Key="BorderMedium" Color="#415060"/>
        <SolidColorBrush x:Key="BorderAccent" Color="#4A8AA8"/>
        <SolidColorBrush x:Key="BorderWarning" Color="#C0882A"/>

        <SolidColorBrush x:Key="TextHigh" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="TextMed" Color="#8FA3B3"/>
        <SolidColorBrush x:Key="TextLow" Color="#566575"/>
        <SolidColorBrush x:Key="TextAccent" Color="#58A6D4"/>
        <SolidColorBrush x:Key="TextWarning" Color="#FFD985"/>
        <SolidColorBrush x:Key="TextDanger" Color="#FFB3A7"/>
        <SolidColorBrush x:Key="TextOk" Color="#7EC882"/>

        <SolidColorBrush x:Key="ComboBg" Color="#3C4A57"/>
        <SolidColorBrush x:Key="ComboBorder" Color="#555F6A"/>
        <SolidColorBrush x:Key="ComboPopupBg" Color="#2D3742"/>
        <SolidColorBrush x:Key="ComboHover" Color="#465565"/>
        <SolidColorBrush x:Key="ComboItemHover" Color="#3E5A70"/>
        <SolidColorBrush x:Key="ComboItemSel" Color="#3C7CA8"/>

        <SolidColorBrush x:Key="BtnSlateBg" Color="#2E3D4E"/>
        <SolidColorBrush x:Key="BtnSlateHover" Color="#374A5C"/>
        <SolidColorBrush x:Key="BtnGreenBg" Color="#1C5C30"/>
        <SolidColorBrush x:Key="BtnGreenHover" Color="#246E39"/>
        <SolidColorBrush x:Key="BtnRedBg" Color="#5C2020"/>
        <SolidColorBrush x:Key="BtnRedHover" Color="#6E2828"/>
        <SolidColorBrush x:Key="BtnWarnBg" Color="#6B4518"/>
        <SolidColorBrush x:Key="BtnWarnHover" Color="#7A5422"/>

        <SolidColorBrush x:Key="WindowBgBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#252B35"/>
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#2C3340"/>
        <SolidColorBrush x:Key="GridBgBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#30404F"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#30404F"/>

        <SolidColorBrush x:Key="TextBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8FA3B3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#566575"/>

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#58A6D4"/>
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#4A8AA8"/>
        <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="#2E3D4E"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#1F4068"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#2F3A4E"/>

        <SolidColorBrush x:Key="DropdownBgBrush" Color="#3C4A57"/>
        <SolidColorBrush x:Key="DropdownPopupBrush" Color="#2D3742"/>
        <SolidColorBrush x:Key="DropdownBorderBrush" Color="#555F6A"/>
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="DropdownArrowBrush" Color="#D7DEE3"/>

        <SolidColorBrush x:Key="SuccessBrush" Color="#1C5C30"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#6B4518"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#5C2020"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMed}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="{StaticResource BgSurfaceAlt}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                        Margin="0,0,0,10">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      TextBlock.Foreground="{StaticResource TextHigh}"
                                                      TextBlock.FontWeight="SemiBold"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" Margin="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="Background" Value="{StaticResource BtnSlateBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMedium}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BtnSlateHover}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnGreenBg}"/>
            <Setter Property="BorderBrush" Value="#2E7D4B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BtnGreenHover}"/>
                    <Setter Property="BorderBrush" Value="#3B8E57"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarnButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnWarnBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderWarning}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BtnWarnHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderWarning}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnRedBg}"/>
            <Setter Property="BorderBrush" Value="#8D3939"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BtnRedHover}"/>
                    <Setter Property="BorderBrush" Value="#A34747"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMedium}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1"
                                        Background="#00000000"
                                        BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        BorderThickness="1,0,0,0"/>

                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="{StaticResource DropdownArrowBrush}"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Style="{StaticResource DarkComboBoxToggleButton}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Margin="8,3,32,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                <TextBox x:Name="PART_EditableTextBox"
                         Margin="8,3,32,3"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         BorderThickness="0"
                         Visibility="Hidden"
                         Focusable="True"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Left"/>

                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid x:Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="{StaticResource DropdownPopupBrush}"
                                BorderBrush="{StaticResource DropdownBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"/>
                        <ScrollViewer Margin="1"
                                      SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>

                <Trigger Property="IsEditable" Value="True">
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DefaultComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DropdownBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownPopupBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemSel}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,12,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource BgRow}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRowAlt}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgRow}"/>
            <Setter Property="MinHeight" Value="34"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgSelection}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgRowHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12"
                Margin="0,0,0,12"
                VerticalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="52"
                        Height="52"
                        Background="{StaticResource BgSurfaceAlt}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="6"
                        Margin="0,0,12,0">
                    <Image x:Name="logoImage"
                           Width="40"
                           Height="40"
                           VerticalAlignment="Center"
                           Opacity="1"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Workset Mapping Manager - pyMENVIC"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextHigh}"/>
                    <TextBlock Text="Review workset mapping, prepare standards, and preview changes before applying them."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.35*"/>
                <ColumnDefinition Width="2.45*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Controls and filters" Margin="0,0,12,0" MinHeight="252">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Discipline" Margin="0,0,8,0" Style="{StaticResource SectionTitleText}"/>
                        <ComboBox x:Name="cmbDisciplineMode"
                                  Grid.Column="1"
                                  Margin="0,0,12,0"
                                  SelectedIndex="0"
                                  Style="{StaticResource DefaultComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                            <ComboBoxItem Content="ARCHITECTURE"/>
                            <ComboBoxItem Content="STRUCTURE"/>
                            <ComboBoxItem Content="MECHANICAL"/>
                            <ComboBoxItem Content="ELECTRICAL"/>
                            <ComboBoxItem Content="PLUMBING"/>
                            <ComboBoxItem Content="SITE"/>
                            <ComboBoxItem Content="COORDINATION"/>
                            <ComboBoxItem Content="ALL DISCIPLINES"/>
                        </ComboBox>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Search" Margin="0,0,8,0" Style="{StaticResource SectionTitleText}"/>
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Margin="0,0,12,0"
                                 ToolTip="Filter by current workset name"/>

                        <TextBlock Grid.Column="2" Text="Action" Margin="0,0,8,0" Style="{StaticResource SectionTitleText}"/>
                        <ComboBox x:Name="cmbActionFilter"
                                  Grid.Column="3"
                                  Margin="0,0,20,0"
                                  SelectedIndex="0"
                                  Style="{StaticResource DefaultComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                            <ComboBoxItem Content="ALL"/>
                            <ComboBoxItem Content="ASSIGN"/>
                            <ComboBoxItem Content="KEEP"/>
                            <ComboBoxItem Content="IGNORE"/>
                            <ComboBoxItem Content="REVIEW"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,0">
                        <Button x:Name="btnSuggestStandards"
                                Content="SUGGEST"
                                Style="{StaticResource MainButtonStyle}"/>
                        <Button x:Name="btnCreateSelectedStandards"
                                Content="CREATE STANDARDS"
                                Style="{StaticResource SuccessButtonStyle}"/>
                        <Button x:Name="btnAnalyze"
                                Content="ANALYZE"
                                Style="{StaticResource MainButtonStyle}"/>
                        <Button x:Name="btnRefresh"
                                Content="REFRESH"
                                Style="{StaticResource MainButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Standards to create" Margin="0,0,12,0" MinHeight="252">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.20*"/>
                        <ColumnDefinition Width="1.30*"/>
                        <ColumnDefinition Width="1.00*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Model" Margin="0,0,8,0">
                        <StackPanel>
                            <CheckBox x:Name="chkARC_MODEL" Content="ARCHITECTURE MODEL"/>
                            <CheckBox x:Name="chkSTR_MODEL" Content="STRUCTURAL MODEL"/>
                            <CheckBox x:Name="chkMECH_MODEL" Content="MECHANICAL MODEL"/>
                            <CheckBox x:Name="chkELE_MODEL" Content="ELECTRICAL MODEL"/>
                            <CheckBox x:Name="chkPLM_MODEL" Content="PLUMBING MODEL"/>
                            <CheckBox x:Name="chkSITE_MODEL" Content="SITE MODEL"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Levels and grids" Margin="0,0,8,0">
                        <StackPanel>
                            <CheckBox x:Name="chkARC_LEVELS_GRIDS" Content="ARCHITECTURE LEVELS &amp; GRIDS"/>
                            <CheckBox x:Name="chkSTR_LEVELS_GRIDS" Content="STRUCTURAL LEVELS &amp; GRIDS"/>
                            <CheckBox x:Name="chkMECH_LEVELS_GRIDS" Content="MECHANICAL LEVELS &amp; GRIDS"/>
                            <CheckBox x:Name="chkELE_LEVELS_GRIDS" Content="ELECTRICAL LEVELS &amp; GRIDS"/>
                            <CheckBox x:Name="chkPLM_LEVELS_GRIDS" Content="PLUMBING LEVELS &amp; GRIDS"/>
                            <CheckBox x:Name="chkSITE_LEVELS_GRIDS" Content="SITE LEVELS &amp; GRIDS"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Links" Margin="0,0,0,0">
                        <StackPanel>
                            <CheckBox x:Name="chkLINK_ARC" Content="LINK ARCHITECTURE"/>
                            <CheckBox x:Name="chkLINK_STR" Content="LINK STRUCTURE"/>
                            <CheckBox x:Name="chkLINK_MECH" Content="LINK MECHANICAL"/>
                            <CheckBox x:Name="chkLINK_ELE" Content="LINK ELECTRICAL"/>
                            <CheckBox x:Name="chkLINK_PLM" Content="LINK PLUMBING"/>
                            <CheckBox x:Name="chkLINK_SITE" Content="LINK SITE"/>
                            <CheckBox x:Name="chkLINK_CAD" Content="LINK CAD"/>
                            <CheckBox x:Name="chkLINK_REF" Content="LINK REFERENCE"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Summary" Margin="0,0,0,0">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rows" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtTotalRows" Grid.Row="0" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Assign" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtMappedRows" Grid.Row="1" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Keep" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtKeepRows" Grid.Row="2" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ignore" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtIgnoreRows" Grid.Row="3" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Review" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtReviewRows" Grid.Row="4" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Standards" FontWeight="SemiBold" Foreground="{StaticResource TextMed}"/>
                    <TextBlock x:Name="txtSelectedStandards" Grid.Row="5" Grid.Column="1" Margin="16,0,0,0" Text="0" FontWeight="Bold"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,12">

            <DataGrid x:Name="dgMappings"
                      ItemsSource="{Binding}"
                      AlternationCount="2"
                      FrozenColumnCount="2"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="CURRENT WORKSET"
                                        Binding="{Binding SourceName}"
                                        Width="220"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="DETECTED TYPE"
                                        Binding="{Binding DetectedType}"
                                        Width="150"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="SUGGESTED TARGET"
                                        Binding="{Binding SuggestedTarget}"
                                        Width="170"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="FINAL TARGET" Width="185">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgSurfaceAlt}"
                                        BorderBrush="{StaticResource BorderMedium}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,4"
                                        Margin="2,1">
                                    <TextBlock Text="{Binding FinalTarget}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextHigh}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableTargets}"
                                          Text="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedItem="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          StaysOpenOnEdit="True"
                                          MinWidth="165"
                                          Padding="4,2"
                                          Margin="0"
                                          Background="{StaticResource ComboBg}"
                                          Foreground="{StaticResource TextHigh}"
                                          BorderBrush="{StaticResource BorderAccent}"
                                          BorderThickness="1"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Left"
                                          Style="{StaticResource DefaultComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                                    <ComboBox.Resources>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Foreground" Value="{StaticResource TextHigh}"/>
                                            <Setter Property="Background" Value="{StaticResource ComboBg}"/>
                                            <Setter Property="CaretBrush" Value="{StaticResource TextHigh}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="2,0,2,0"/>
                                        </Style>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItemStyle}"/>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTION" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableActions}"
                                          SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          MinWidth="90"
                                          Padding="4,2"
                                          Margin="0"
                                          Background="{StaticResource DropdownBgBrush}"
                                          Foreground="{StaticResource DropdownTextBrush}"
                                          BorderBrush="{StaticResource BorderAccent}"
                                          Style="{StaticResource DefaultComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="ELEMENTS"
                                        Binding="{Binding ElementCount}"
                                        Width="100"
                                        IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="ELEMENTS"
                                           Width="80"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="TARGET COUNT"
                                        Binding="{Binding TargetElementCount}"
                                        Width="140"
                                        IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="TARGET COUNT"
                                           Width="140"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="REASON"
                                        Binding="{Binding Reason}"
                                        Width="400"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10"
                    Margin="0,0,12,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <CheckBox x:Name="chkRenameDuplicates"
                                  Content="RENAME / CONSOLIDATE DUPLICATES"/>
                        <CheckBox x:Name="chkDeleteEmptyAfterMap"
                                  Content="DELETE EMPTY LEFTOVERS AFTER APPLY"/>
                    </StackPanel>

                    <TextBlock x:Name="txtStatus"
                               Grid.Column="1"
                               Text="Ready to review changes."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="10,0,4,0"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnDeleteEmptyWorksets"
                        Content="DELETE EMPTY"
                        Style="{StaticResource MainButtonStyle}"/>
                <Button x:Name="btnPreview"
                        Content="PREVIEW"
                        Style="{StaticResource WarnButtonStyle}"/>
                <Button x:Name="btnApply"
                        Content="APPLY"
                        Style="{StaticResource SuccessButtonStyle}"/>
                <Button x:Name="btnClose"
                        Content="CLOSE"
                        Style="{StaticResource CloseButtonStyle}"
                        Margin="0,0,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
