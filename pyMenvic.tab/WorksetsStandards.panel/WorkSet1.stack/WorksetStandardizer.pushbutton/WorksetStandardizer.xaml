<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workset Standardizer"
        Height="920"
        Width="1560"
        MinHeight="760"
        MinWidth="1280"
        Background="#3B4453"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <SolidColorBrush x:Key="WindowBgBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#314854"/>
        <SolidColorBrush x:Key="GridBgBrush" Color="#3B4453"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>

        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#D7DEE3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9A9A9A"/>

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#6D97AE"/>
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#5D8194"/>
        <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="#416172"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#3E5A6B"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#354D5C"/>

        <SolidColorBrush x:Key="DropdownBgBrush" Color="#252526"/>
        <SolidColorBrush x:Key="DropdownPopupBrush" Color="#252526"/>
        <SolidColorBrush x:Key="DropdownBorderBrush" Color="#6D97AE"/>
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DropdownArrowBrush" Color="#D7DEE3"/>

        <SolidColorBrush x:Key="SuccessBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#EF6C00"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#B71C1C"/>

        <SolidColorBrush x:Key="ReadableOptionTextBrush" Color="#E8EEF2"/>
        <SolidColorBrush x:Key="StatusStandardBgBrush" Color="#365343"/>
        <SolidColorBrush x:Key="StatusAssignableBgBrush" Color="#4C7FA4"/>
        <SolidColorBrush x:Key="StatusReviewBgBrush" Color="#7A5B2F"/>
        <SolidColorBrush x:Key="StatusKeepBgBrush" Color="#5A4C71"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource AccentBlueDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        </Style>

        <Style x:Key="WarnButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource WarnBrush}"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="{StaticResource DropdownBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1"
                                        Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        BorderThickness="1,0,0,0"/>

                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="{StaticResource DropdownArrowBrush}"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Style="{StaticResource DarkComboBoxToggleButton}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Margin="8,3,32,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                <TextBox x:Name="PART_EditableTextBox"
                         Margin="8,3,32,3"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         BorderThickness="0"
                         Visibility="Hidden"
                         Focusable="True"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Left"/>

                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid x:Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="{StaticResource DropdownPopupBrush}"
                                BorderBrush="{StaticResource DropdownBorderBrush}"
                                BorderThickness="1"/>
                        <ScrollViewer Margin="1"
                                      SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>

                <Trigger Property="IsEditable" Value="True">
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DefaultComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DropdownBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownPopupBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ReadableOptionTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DataGridTextCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="DataGridEditingTextStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="DataGridCellComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SecondaryPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SecondaryPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource SecondaryPanelBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SecondaryPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SecondaryPanelBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource GridLineBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="6"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="logoImage"
                       Grid.Column="0"
                       Width="40"
                       Height="40"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Workset Standardizer – pyMENVIC"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Analyze existing worksets, load one discipline profile, review editable suggestions, then rename or consolidate worksets safely."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.30*"/>
                <ColumnDefinition Width="1.90*"/>
                <ColumnDefinition Width="0.75*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Mode and filters" Margin="0,0,10,0" MinHeight="150" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Discipline:" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbDisciplineMode"
                                  Grid.Column="1"
                                  Margin="0,0,12,0"
                                  SelectedIndex="0"
                                  Style="{StaticResource DefaultComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                            <ComboBoxItem Content="ARCHITECTURE"/>
                            <ComboBoxItem Content="STRUCTURE"/>
                            <ComboBoxItem Content="MECHANICAL"/>
                            <ComboBoxItem Content="ELECTRICAL"/>
                            <ComboBoxItem Content="PLUMBING"/>
                            <ComboBoxItem Content="SITE"/>
                            <ComboBoxItem Content="COORDINATION"/>
                        </ComboBox>

                        <CheckBox x:Name="chkIncludeLinks"
                                  Grid.Column="2"
                                  Content="INCLUDE LINK WORKSET"
                                  Style="{StaticResource ReadableCheckBoxStyle}"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Search:" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Margin="0,0,12,0"/>

                        <TextBlock Grid.Column="2" Text="Action:" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbActionFilter"
                                  Grid.Column="3"
                                  Margin="0,0,12,0"
                                  SelectedIndex="0"
                                  Style="{StaticResource DefaultComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                            <ComboBoxItem Content="ALL"/>
                            <ComboBoxItem Content="NO ACTION"/>
                            <ComboBoxItem Content="ASSIGN TO TARGET"/>
                            <ComboBoxItem Content="REVIEW"/>
                            <ComboBoxItem Content="KEEP BY USER"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="btnSuggestStandards"
                                Content="SUGGEST STANDARDS"
                                Style="{StaticResource MainButtonStyle}"/>
                        <Button x:Name="btnCreateSelectedStandards"
                                Content="CREATE SELECTED STANDARDS"
                                Style="{StaticResource SuccessButtonStyle}"/>
                        <Button x:Name="btnAnalyze"
                                Content="ANALYZE"
                                Style="{StaticResource MainButtonStyle}"/>
                        <Button x:Name="btnRefresh"
                                Content="REFRESH"
                                Style="{StaticResource MainButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Active targets" Margin="0,0,10,0" MinHeight="150" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Available targets for active discipline."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <ListBox x:Name="lstActiveTargets"
                             Grid.Row="1"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Margin" Value="0,0,8,4"/>
                                <Setter Property="Width" Value="145"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- <GroupBox Grid.Column="2" Header="Analysis Summary" Margin="0,0,10,0" MinHeight="150" VerticalAlignment="Stretch">
                <Grid Margin="0" MinHeight="150" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions> -->

            <GroupBox Grid.Column="2" Header="Analysis Summary" Margin="0,0,10,0" MinHeight="150" VerticalAlignment="Stretch">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Rows:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalRows" Grid.Row="0" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Standard:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtStandardRows" Grid.Row="1" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Assignable:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtAssignableRows" Grid.Row="2" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Needs Review:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtReviewRows" Grid.Row="3" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Keep by User:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtKeepByUserRows" Grid.Row="4" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Targets:" FontWeight="Bold"/>
                    <TextBlock x:Name="txtSelectedStandards" Grid.Row="5" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,10">

            <DataGrid x:Name="dgMappings"
                      ItemsSource="{Binding}"
                      FrozenColumnCount="2"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="CURRENT WORKSET"
                                        Binding="{Binding SourceName}"
                                        Width="220"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="STATUS" Width="150" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBadge"
                                        Background="{StaticResource StatusReviewBgBrush}"
                                        BorderBrush="#D9E4EC"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="11"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="STANDARD">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusStandardBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="ASSIGNABLE">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusAssignableBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="NEEDS REVIEW">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusReviewBgBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Action}" Value="KEEP BY USER">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusKeepBgBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="SUGGESTED TARGET"
                                        Binding="{Binding SuggestedTarget}"
                                        Width="180"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="FINAL TARGET" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableTargets}"
                                          SelectedItem="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Text="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          StaysOpenOnEdit="True"
                                          MinWidth="200"
                                          Style="{StaticResource DataGridCellComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Action" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableActions}"
                                          SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          MinWidth="150"
                                          Style="{StaticResource DataGridCellComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="ELEMENTS"
                                        Binding="{Binding ElementCount}"
                                        Width="90"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="PLANNED RESULT"
                                        Binding="{Binding Result}"
                                        Width="170"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="REASON"
                                        Binding="{Binding Reason}"
                                        Width="320"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="chkShowStandard"
                              Content="SHOW STANDARDS"
                              Style="{StaticResource ReadableCheckBoxStyle}"/>
                    <CheckBox x:Name="chkRenameDuplicates"
                              Content="CONSOLIDATE DUPLICATE / EQUIVALENT NAMES"
                              Style="{StaticResource ReadableCheckBoxStyle}"/>
                    <CheckBox x:Name="chkDeleteEmptyAfterMap"
                              Content="DELETE EMPTY LEFTOVERS AFTER APPLY"
                              Style="{StaticResource ReadableCheckBoxStyle}"/>
                </StackPanel>

                <TextBlock x:Name="txtStatus"
                           Grid.Column="1"
                           Text="Ready."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,16,0"/>
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnPreview"
                        Content="UPDATE PLAN"
                        Style="{StaticResource WarnButtonStyle}"/>
                <Button x:Name="btnApply"
                        Content="APPLY"
                        Style="{StaticResource SuccessButtonStyle}"/>
                <Button x:Name="btnClose"
                        Content="CLOSE"
                        Style="{StaticResource CloseButtonStyle}"
                        Margin="0,0,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>