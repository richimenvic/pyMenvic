<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workset Standardizer"
        Height="920"
        Width="1560"
        MinHeight="760"
        MinWidth="1280"
        Background="#1C2128"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- Base palette -->
        <SolidColorBrush x:Key="BgAppBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="BgSurfaceBrush" Color="#252B35"/>
        <SolidColorBrush x:Key="BgSurfaceAltBrush" Color="#2C3340"/>
        <SolidColorBrush x:Key="BgInputBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="BgRowBrush" Color="#252B35"/>
        <SolidColorBrush x:Key="BgRowAltBrush" Color="#2A3040"/>
        <SolidColorBrush x:Key="BgRowHoverBrush" Color="#2F3A4E"/>
        <SolidColorBrush x:Key="BgSelectionBrush" Color="#1F4068"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#1E2730"/>

        <SolidColorBrush x:Key="BgPendingBrush" Color="#1E3528"/>
        <SolidColorBrush x:Key="BgReviewBrush" Color="#3A2418"/>

        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#30404F"/>
        <SolidColorBrush x:Key="BorderMediumBrush" Color="#415060"/>
        <SolidColorBrush x:Key="BorderAccentBrush" Color="#4A8AA8"/>
        <SolidColorBrush x:Key="BorderWarningBrush" Color="#C0882A"/>

        <SolidColorBrush x:Key="TextHighBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="TextMedBrush" Color="#8FA3B3"/>
        <SolidColorBrush x:Key="TextLowBrush" Color="#566575"/>
        <SolidColorBrush x:Key="TextAccentBrush" Color="#58A6D4"/>
        <SolidColorBrush x:Key="TextWarningBrush" Color="#FFD985"/>
        <SolidColorBrush x:Key="TextDangerBrush" Color="#FFB3A7"/>
        <SolidColorBrush x:Key="TextOkBrush" Color="#7EC882"/>

        <SolidColorBrush x:Key="ComboBgBrush" Color="#3C4A57"/>
        <SolidColorBrush x:Key="ComboBorderBrush" Color="#555F6A"/>
        <SolidColorBrush x:Key="ComboPopupBgBrush" Color="#2D3742"/>
        <SolidColorBrush x:Key="ComboHoverBrush" Color="#465565"/>
        <SolidColorBrush x:Key="ComboItemHoverBrush" Color="#3E5A70"/>
        <SolidColorBrush x:Key="ComboItemSelBrush" Color="#3C7CA8"/>

        <SolidColorBrush x:Key="BtnSlateBgBrush" Color="#2E3D4E"/>
        <SolidColorBrush x:Key="BtnSlateHoverBrush" Color="#374A5C"/>
        <SolidColorBrush x:Key="BtnGreenBgBrush" Color="#1C5C30"/>
        <SolidColorBrush x:Key="BtnGreenHoverBrush" Color="#246E39"/>
        <SolidColorBrush x:Key="BtnRedBgBrush" Color="#5C2020"/>
        <SolidColorBrush x:Key="BtnRedHoverBrush" Color="#6E2828"/>

        <!-- Compatibility aliases for existing references -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#252B35"/>
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#2C3340"/>
        <SolidColorBrush x:Key="GridBgBrush" Color="#2A3040"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#30404F"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#30404F"/>

        <SolidColorBrush x:Key="TextBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8FA3B3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#566575"/>

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#58A6D4"/>
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#4A8AA8"/>
        <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="#2E3D4E"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#1F4068"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#2F3A4E"/>

        <SolidColorBrush x:Key="DropdownBgBrush" Color="#3C4A57"/>
        <SolidColorBrush x:Key="DropdownPopupBrush" Color="#2D3742"/>
        <SolidColorBrush x:Key="DropdownBorderBrush" Color="#555F6A"/>
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="DropdownArrowBrush" Color="#8FA3B3"/>

        <SolidColorBrush x:Key="SuccessBrush" Color="#1C5C30"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#C0882A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#5C2020"/>

        <SolidColorBrush x:Key="ReadableOptionTextBrush" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="StatusStandardBgBrush" Color="#1E3528"/>
        <SolidColorBrush x:Key="StatusAssignableBgBrush" Color="#1F4068"/>
        <SolidColorBrush x:Key="StatusReviewBgBrush" Color="#3A2418"/>
        <SolidColorBrush x:Key="StatusKeepBgBrush" Color="#2E3D4E"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
        </Style>

        <Style x:Key="SectionHelpTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12,11,12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="{StaticResource HeaderBgBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="8,8,0,0"
                                        Padding="12,9,12,8">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Border>
                                <ContentPresenter Grid.Row="1"
                                                  Margin="12,11,12,10"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
            <Setter Property="Background" Value="{StaticResource BtnSlateBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BtnSlateHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnGreenBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BtnGreenHoverBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BtnGreenHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource TextOkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource TextOkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarnButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnSlateBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderWarningBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWarningBrush}"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BtnRedBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BtnRedHoverBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BtnRedHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource TextDangerBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource TextDangerBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComboBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1"
                                        Background="#22000000"
                                        BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        BorderThickness="1,0,0,0"
                                        CornerRadius="0,6,6,0"/>

                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="{StaticResource DropdownArrowBrush}"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Style="{StaticResource DarkComboBoxToggleButton}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Margin="10,3,34,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                <TextBox x:Name="PART_EditableTextBox"
                         Margin="10,3,34,3"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         BorderThickness="0"
                         Visibility="Hidden"
                         Focusable="True"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>

                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid x:Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="{StaticResource DropdownPopupBrush}"
                                BorderBrush="{StaticResource BorderMediumBrush}"
                                BorderThickness="1"
                                CornerRadius="6"/>
                        <ScrollViewer Margin="1"
                                      SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>

                <Trigger Property="IsEditable" Value="True">
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DefaultComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource ComboBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComboBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownPopupBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemSelBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ReadableOptionTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DataGridTextCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
        </Style>

        <Style x:Key="DataGridTextCellCenteredStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridTextCellTextStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CenteredColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DataGridEditingTextStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
        </Style>

        <Style x:Key="DataGridCellComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>

        <ControlTemplate x:Key="FinalTargetComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Style="{StaticResource DarkComboBoxToggleButton}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Margin="10,0,34,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                <TextBox x:Name="PART_EditableTextBox"
                         Margin="10,0,34,0"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         BorderThickness="0"
                         Visibility="Hidden"
                         Focusable="True"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Left"/>

                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid x:Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="{StaticResource DropdownPopupBrush}"
                                BorderBrush="{StaticResource BorderMediumBrush}"
                                BorderThickness="1"
                                CornerRadius="6"/>
                        <ScrollViewer Margin="1"
                                      SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>

                <Trigger Property="IsEditable" Value="True">
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="FinalTargetColumnComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DataGridCellComboBoxStyle}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template" Value="{StaticResource FinalTargetComboBoxTemplate}"/>
        </Style>

        <ControlTemplate x:Key="ActionComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Style="{StaticResource DarkComboBoxToggleButton}"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Margin="10,0,34,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                <TextBox x:Name="PART_EditableTextBox"
                         Margin="10,0,34,3"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         BorderThickness="0"
                         Visibility="Hidden"
                         Focusable="True"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>

                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid x:Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="{StaticResource DropdownPopupBrush}"
                                BorderBrush="{StaticResource BorderMediumBrush}"
                                BorderThickness="1"
                                CornerRadius="6"/>
                        <ScrollViewer Margin="1"
                                      SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>

                <Trigger Property="IsEditable" Value="True">
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ActionColumnComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DataGridCellComboBoxStyle}">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template" Value="{StaticResource ActionComboBoxTemplate}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource BgSurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgSurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{StaticResource BgRowBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRowAltBrush}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextHighBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgRowBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgSelectionBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="16,14,16,14">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBgBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,16"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="52"
                        Height="52"
                        CornerRadius="8"
                        Background="{StaticResource BgSurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderMediumBrush}"
                        BorderThickness="1"
                        Margin="0,0,14,0">
                    <Image x:Name="logoImage"
                           Width="30"
                           Height="30"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Workset Standardizer"
                               Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Review current worksets, load the active discipline profile, then confirm the target mapping before applying changes."
                               Margin="0,6,0,0"
                               Style="{StaticResource SectionHelpTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{StaticResource BgAppBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.35*"/>
                    <ColumnDefinition Width="1.85*"/>
                    <ColumnDefinition Width="0.90*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="Controls and filters" Margin="0,0,12,0" MinHeight="126" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Discipline" Margin="0,0,10,0" Foreground="{StaticResource TextMedBrush}"/>
                            <ComboBox x:Name="cmbDisciplineMode"
                                      Grid.Column="1"
                                      Margin="0,0,14,0"
                                      SelectedIndex="0"
                                      Style="{StaticResource DefaultComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                                <ComboBoxItem Content="ARCHITECTURE"/>
                                <ComboBoxItem Content="STRUCTURE"/>
                                <ComboBoxItem Content="MECHANICAL"/>
                                <ComboBoxItem Content="ELECTRICAL"/>
                                <ComboBoxItem Content="PLUMBING"/>
                                <ComboBoxItem Content="SITE"/>
                                <ComboBoxItem Content="COORDINATION"/>
                            </ComboBox>

                            <CheckBox x:Name="chkIncludeLinks"
                                      Grid.Column="2"
                                      Content="Include linked worksets"
                                      Style="{StaticResource ReadableCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Filter" Margin="0,0,10,0" Foreground="{StaticResource TextMedBrush}"/>
                            <TextBox x:Name="txtSearch"
                                     Grid.Column="1"
                                     Margin="0,0,14,0"/>

                            <TextBlock Grid.Column="2" Text="Action" Margin="0,0,10,0" Foreground="{StaticResource TextMedBrush}"/>
                            <ComboBox x:Name="cmbActionFilter"
                                      Grid.Column="3"
                                      Margin="0,0,12,0"
                                      SelectedIndex="0"
                                      Style="{StaticResource DefaultComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                                <ComboBoxItem Content="ALL"/>
                                <ComboBoxItem Content="IGNORE"/>
                                <ComboBoxItem Content="ASSIGN"/>
                                <ComboBoxItem Content="REVIEW"/>
                                <ComboBoxItem Content="KEEP"/>
                            </ComboBox>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,0">
                            <Button x:Name="btnSuggestStandards"
                                    Content="SUGGEST TARGETS"
                                    Style="{StaticResource MainButtonStyle}"/>
                            <Button x:Name="btnCreateSelectedStandards"
                                    Content="CREATE SELECTED"
                                    Style="{StaticResource SuccessButtonStyle}"/>
                            <Button x:Name="btnAnalyze"
                                    Content="ANALYZE"
                                    Style="{StaticResource MainButtonStyle}"/>
                            <Button x:Name="btnRefresh"
                                    Content="REFRESH"
                                    Style="{StaticResource MainButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Active targets" Margin="0,0,12,0" MinHeight="126" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Targets available for the selected discipline."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,0,0,6"
                                   TextWrapping="Wrap"/>

                        <ListBox x:Name="lstActiveTargets"
                                 Grid.Row="1"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="Margin" Value="0,0,8,6"/>
                                    <Setter Property="Width" Value="145"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBrush}"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectionBrush}"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="Summary" Margin="0" MinHeight="126" VerticalAlignment="Stretch">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Rows" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtTotalRows" Grid.Row="0" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Standard" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtStandardRows" Grid.Row="1" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Assignable" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtAssignableRows" Grid.Row="2" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Review" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtReviewRows" Grid.Row="3" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Keep" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtKeepByUserRows" Grid.Row="4" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Targets" FontWeight="SemiBold" Foreground="{StaticResource TextMedBrush}"/>
                        <TextBlock x:Name="txtSelectedStandards" Grid.Row="5" Grid.Column="1" Text="0" HorizontalAlignment="Right"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>

        <!-- Main DataGrid -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,14">

            <DataGrid x:Name="dgMappings"
                      ItemsSource="{Binding}"
                      FrozenColumnCount="2"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="CURRENT WORKSET"
                                        Binding="{Binding SourceName}"
                                        Width="214"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="STATUS" Width="148" IsReadOnly="True"
                                            HeaderStyle="{StaticResource CenteredColumnHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <Border x:Name="StatusBadge"
                                            Background="{StaticResource StatusReviewBgBrush}"
                                            BorderBrush="{StaticResource BorderWarningBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextHighBrush}"
                                                   FontSize="11"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="STANDARD">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusStandardBgBrush}"/>
                                        <Setter TargetName="StatusBadge" Property="BorderBrush" Value="{StaticResource TextOkBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="ASSIGNABLE">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusAssignableBgBrush}"/>
                                        <Setter TargetName="StatusBadge" Property="BorderBrush" Value="{StaticResource BorderAccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="NEEDS REVIEW">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusReviewBgBrush}"/>
                                        <Setter TargetName="StatusBadge" Property="BorderBrush" Value="{StaticResource BorderWarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Action}" Value="KEEP">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource StatusKeepBgBrush}"/>
                                        <Setter TargetName="StatusBadge" Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="SUGGESTED TARGET"
                                        Binding="{Binding SuggestedTarget}"
                                        Width="188"
                                        HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                        ElementStyle="{StaticResource DataGridTextCellCenteredStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="FINAL TARGET" Width="232" HeaderStyle="{StaticResource CenteredColumnHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#14000000"
                                        BorderBrush="{StaticResource BorderAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="1"
                                        Margin="6,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <ComboBox ItemsSource="{Binding AvailableTargets}"
                                              SelectedItem="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Text="{Binding FinalTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True"
                                              MinWidth="200"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"
                                              Style="{StaticResource FinalTargetColumnComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTION" Width="160" HeaderStyle="{StaticResource CenteredColumnHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableActions}"
                                          SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          MinWidth="150"
                                          HorizontalAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource ActionColumnComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="ELEMENTS"
                                        Binding="{Binding ElementCount}"
                                        Width="92"
                                        HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                        ElementStyle="{StaticResource DataGridTextCellCenteredStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="RESULT"
                                        Binding="{Binding Result}"
                                        Width="182"
                                        HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                        ElementStyle="{StaticResource DataGridTextCellCenteredStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="NOTES"
                                        Binding="{Binding Reason}"
                                        Width="*"
                                        MinWidth="300"
                                        ElementStyle="{StaticResource DataGridTextCellTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="chkShowStandard"
                                  Content="Show standard rows"
                                  Style="{StaticResource ReadableCheckBoxStyle}"/>
                        <CheckBox x:Name="chkRenameDuplicates"
                                  Content="Merge duplicate or equivalent names"
                                  Style="{StaticResource ReadableCheckBoxStyle}"/>
                        <CheckBox x:Name="chkDeleteEmptyAfterMap"
                                  Content="Delete empty leftovers after apply"
                                  Style="{StaticResource ReadableCheckBoxStyle}"/>
                    </StackPanel>

                    <TextBlock x:Name="txtStatus"
                               Grid.Column="1"
                               Text="Ready."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,16,0"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPreview"
                            Content="REVIEW PLAN"
                            Style="{StaticResource WarnButtonStyle}"/>
                    <Button x:Name="btnApply"
                            Content="APPLY"
                            Style="{StaticResource SuccessButtonStyle}"/>
                    <Button x:Name="btnClose"
                            Content="CLOSE"
                            Style="{StaticResource CloseButtonStyle}"
                            Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
