<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link Workset Manager"
        Height="860"
        Width="1320"
        MinHeight="720"
        MinWidth="1080"
        Background="#252526"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="WindowBgBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="SecondaryPanelBrush" Color="#314854"/>
        <SolidColorBrush x:Key="GridBgBrush" Color="#3B4453"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#4A4A4A"/>

        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#D7DEE3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9A9A9A"/>

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#6D97AE"/>
<!-- color de la seleccion -->
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#5D8194"/>
        <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="#416172"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#5B8AA3"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3E5A6B"/>

        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#4E7082"/>
        <SolidColorBrush x:Key="DropdownPopupBrush" Color="#2B2B31"/>
        <SolidColorBrush x:Key="DropdownBorderBrush" Color="#4E7082"/>
<!-- color del texto de la seleccion FFFFFF-->
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#FFFFFF"/>

        <SolidColorBrush x:Key="PendingBrush" Color="#415E70"/>
        <SolidColorBrush x:Key="ReviewBrush" Color="#6F5A3A"/>
        <SolidColorBrush x:Key="ReviewBorderBrush" Color="#D0A14A"/>
        <SolidColorBrush x:Key="WarningTextBrush" Color="#FFD985"/>
        <SolidColorBrush x:Key="StatusDotBrush" Color="#D8AA3C"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="ApplyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#3F8F46"/>
            <Setter Property="BorderBrush" Value="#4FA558"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinWidth" Value="128"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4AA352"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#B3261E"/>
            <Setter Property="BorderBrush" Value="#C93B32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinWidth" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C93B32"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#202327"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="ComboToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="26"/>
                    </Grid.ColumnDefinitions>

                    <ContentPresenter Grid.Column="0"
                                      Margin="8,0,4,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>

                    <Border Grid.Column="1"
                            Background="#3E5A6B"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,0,0,0">
                        <Path x:Name="Arrow"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Width="8"
                              Height="4"
                              Stretch="Fill"
                              Fill="{StaticResource DropdownTextBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource AccentBlueHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource AccentBlueDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="GridComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownPopupBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource DropdownTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource DropdownBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DropdownBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource GridComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="KeyboardNavigation.IsTabStop" Value="False"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource GridBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ToolTip" Value="{Binding WarningText}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUnrecognized}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ReviewBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="88"/>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SecondaryPanelBrush}"
                    BorderBrush="{StaticResource GridLineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <DockPanel LastChildFill="True">
                    <Border Width="60"
                            Height="60"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0">
                        <Image x:Name="logoImage"
                               Stretch="Uniform"
                               Margin="8"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Link Workset Manager"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Auto-detects link discipline and preselects target workset."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SecondaryPanelBrush}"
                    BorderBrush="{StaticResource GridLineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnRefresh"
                            Content="REFRESH"
                            Grid.Column="0"
                            Style="{StaticResource ToolbarButtonStyle}"/>

                    <TextBlock Grid.Column="2"
                               Text="FILTER:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtFilter"
                             Grid.Column="3"
                             Style="{StaticResource FilterTextBoxStyle}"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource GridBgBrush}"
                    BorderBrush="{StaticResource GridLineBrush}"
                    BorderThickness="0">
                <DataGrid x:Name="dgLinks"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="LINK NAME"
                                            Binding="{Binding LinkName}"
                                            Width="2.10*"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TYPE NAME"
                                            Binding="{Binding TypeName}"
                                            Width="1.80*"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="INST WS"
                                            Binding="{Binding CurrentInstanceWorkset}"
                                            Width="0.92*"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TYPE WS"
                                            Binding="{Binding CurrentTypeWorkset}"
                                            Width="0.92*"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="STATUS"
                                            Binding="{Binding Status}"
                                            Width="82"
                                            CanUserResize="False"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PIN"
                                            Binding="{Binding PinnedText}"
                                            Width="54"
                                            CanUserResize="False"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DISCIPLINE"
                                            Binding="{Binding DisciplineText}"
                                            Width="96"
                                            CanUserResize="False"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="STATE"
                                            Binding="{Binding StateText}"
                                            Width="88"
                                            CanUserResize="False"
                                            IsReadOnly="False">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredTextBlockStyle}">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StateText}" Value="OK">
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StateText}" Value="CHANGE">
                                            <Setter Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StateText}" Value="REVIEW">
                                            <Setter Property="Foreground" Value="#FFB3A7"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header=""
                                                Width="34"
                                                CanUserResize="False"
                                                IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent"
                                          ToolTip="{Binding WarningText}">
                                        <TextBlock Text="!"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource WarningTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsUnrecognized, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="TARGET WORKSET" Width="1.08*">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource GridBgBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPendingChange}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PendingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsUnrecognized}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource ReviewBorderBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent"
                                          ToolTip="{Binding WarningText}">
                                        <TextBlock Text="{Binding SelectedTargetWorksetName}"
                                                   Margin="8,0,24,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <Grid Background="Transparent"
                                          ToolTip="{Binding WarningText}">
                                        <ComboBox ItemsSource="{Binding WorksetOptions}"
                                                  Text="{Binding SelectedTargetWorksetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedItem="{Binding SelectedTargetWorksetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource GridComboStyle}"
                                                  MinWidth="140"
                                                  FocusVisualStyle="{x:Null}"
                                                  IsEditable="True"
                                                  IsReadOnly="False"
                                                  IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True"
                                                  Background="{StaticResource DropdownBackgroundBrush}"
                                                  Foreground="Black"
                                                  BorderBrush="{StaticResource DropdownBorderBrush}">
                                            <ComboBox.Resources>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Setter Property="CaretBrush" Value="Black"/>
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="4,0,4,0"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource SecondaryPanelBrush}"
                    BorderBrush="{StaticResource GridLineBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="txtStatus"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Links: 0 | OK: 0 | Pending: 0 | Review: 0"/>

                    <Button x:Name="btnApply"
                            Content="APPLY"
                            Grid.Column="1"
                            Style="{StaticResource ApplyButtonStyle}"
                            Margin="0,0,10,0"/>

                    <Button x:Name="btnCancel"
                            Content="CLOSE"
                            Grid.Column="2"
                            Style="{StaticResource CloseButtonStyle}"
                            MinWidth="90"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
