<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About pyMenvic"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E252B"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F4B5E"/>
            <Setter Property="BorderBrush" Value="#4C6B82"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="#1E252B">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F4F6F8" Margin="10,12,10,6" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="180"
                        Height="180"
                        CornerRadius="14"
                        Background="#F7F9FB"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        BorderBrush="#D7E0E7"
                        BorderThickness="1">
                    <Image x:Name="logo"
                            Stretch="UniformToFill"
                            Margin="16"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock x:Name="titleText"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1E252B"
                               Text="pyMenvic — Version 1.0.0"/>

                    <TextBlock x:Name="descText"
                               Margin="0,12,0,8"
                               FontSize="13"
                               Foreground="#1E252B"
                               TextWrapping="Wrap"
                               Text="Tools and utilities to improve productivity in Revit."/>

                    <TextBlock x:Name="envText"
                               Margin="0,0,0,14"
                               FontSize="12"
                               Foreground="#1E252B"
                               Opacity="0.85"
                               TextWrapping="Wrap"
                               Text=""/>

                    <Separator Margin="0,6,0,10"/>

                    <TextBlock FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#1E252B"
                               Text="MENVIC ARQ"/>

                    <TextBlock Opacity="0.85"
                               Margin="0,2,0,6"
                               Foreground="#1E252B"
                               Text="Developed by Ricardo J. Mendieta"/>

                    <TextBlock Text="Contact"
                               Foreground="#1E252B"
                               FontWeight="Bold"
                               Margin="0,8,0,3"/>

                    <TextBlock x:Name="emailText"
                               Foreground="#1E252B"
                               Text="contact@menvic.com"/>

                    <TextBlock x:Name="yearText"
                               Margin="0,12,0,0"
                               Foreground="#1E252B"
                               Text="© 2026"/>

                    <StackPanel Orientation="Vertical" Margin="0,22,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="webBtn"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Content="Website"
                                    Width="100"/>

                            <Button x:Name="copyEmailBtn"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Content="Copy Email"
                                    Width="120"
                                    Margin="10,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="checkUpdatesBtn"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Content="Check for Updates"
                                    Width="230"
                                    Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#1E252B" Padding="10,3,10,4">
            <TextBlock Text="pyMenvic"
                       Foreground="#A9BAC8"
                       FontSize="12"
                       HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</Window>
