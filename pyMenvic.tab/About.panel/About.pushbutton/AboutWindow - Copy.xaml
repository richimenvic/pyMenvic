<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About pyMenvic"
        Height="350"
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LOGO -->
        <Border Grid.Column="0"
                Width="130"
                Height="130"
                CornerRadius="14"
                Background="#F3F3F3"
                VerticalAlignment="Top"
                HorizontalAlignment="Center">
            <Image x:Name="logo" Stretch="Uniform" Margin="12"/>
        </Border>

        <!-- TEXT -->
        <StackPanel Grid.Column="1" Margin="16,0,0,0">

            <!-- TITLE -->
            <TextBlock x:Name="titleText"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1F4E79"
                       Text="pyMenvic - Version 1.0"/>

            <!-- DESCRIPTION -->
            <TextBlock x:Name="descText"
                       Margin="0,10,0,6"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Text="Tools and utilities to improve productivity in Revit."/>

            <TextBlock x:Name="envText"
                       Margin="0,0,0,10"
                       FontSize="12"
                       Opacity="0.85"
                       TextWrapping="Wrap"
                       Text=""/>

            <!-- SEPARATOR -->
            <Separator Margin="0,6,0,10"/>

            <!-- ORGANIZATION -->
            <TextBlock FontWeight="Bold"
                       FontSize="13"
                       Text="MENVIC ARQ"/>

            <TextBlock Opacity="0.85"
                       Margin="0,2,0,6"
                       Text="Developed by Ricardo J. Mendieta"/>

            <!-- CONTACT -->
            <TextBlock Text="CONTACT"
                       FontWeight="Bold"
                       Margin="0,8,0,3"/>

            <TextBlock x:Name="emailText"
                       Text="contact@menvic.com"/>

            <!-- COPYRIGHT -->
            <TextBlock x:Name="yearText"
                       Margin="0,12,0,0"
                       Text="© 2026"/>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">

                <Button x:Name="webBtn"
                        Content="Website"
                        Width="100"
                        Height="32"
                        BorderBrush="#707070"
                        BorderThickness="1"
                        Background="#F5F5F5"/>

                <Button x:Name="copyEmailBtn"
                        Content="Copy Email"
                        Width="120"
                        Height="32"
                        Margin="10,0,0,0"
                        BorderBrush="#707070"
                        BorderThickness="1"
                        Background="#F5F5F5"/>

                <Button x:Name="closeBtn"
                        Content="Close"
                        Width="100"
                        Height="32"
                        Margin="10,0,0,0"
                        BorderBrush="#707070"
                        BorderThickness="1"
                        Background="#F5F5F5"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>